@{
    var ctrl = (ViewBag.Ctrl ?? "").ToString();
    var action = (ViewContext.RouteData.Values["action"] ?? "").ToString();
    var title = (ViewBag.Title ?? "Hệ thống phòng khám").ToString();
    var role = (Session["UserRole"] ?? "").ToString();
    var userName = (Session["UserName"] ?? "Người dùng").ToString();
    var shortName = userName.Contains(" ") ? userName.Split(' ').Last() : userName;
    var initial = !string.IsNullOrWhiteSpace(userName) ? userName.Substring(0, 1).ToUpper() : "U";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - MedicCare</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="~/Content/clinic.css?v=@DateTime.Now.Ticks" rel="stylesheet" />
</head>
<body>
    <div class="wrapper">
        <aside class="sidebar">
            <div class="sb-brand">
                <i class="fas fa-hospital-alt me-2" style="color:#60a5fa"></i>MedicCare
            </div>

            <div class="sb-nav">
                @if (role == "Admin")
                {
                    <div class="nav-section">Tổng quan</div>
                    <a class="@(ctrl == "Admin" ? "active" : "")" href="@Url.Action("Index", "Admin")">
                        <i class="fas fa-chart-line"></i><span>Dashboard</span>
                    </a>

                    <div class="nav-section">Nhân sự</div>
                    <a class="@(ctrl == "Doctor" ? "active" : "")" href="@Url.Action("Index", "Doctor")">
                        <i class="fas fa-user-doctor"></i><span>Bác sĩ</span>
                    </a>
                    <a class="@(ctrl == "Receptionist" ? "active" : "")" href="@Url.Action("Index", "Receptionist")">
                        <i class="fas fa-concierge-bell"></i><span>Lễ tân</span>
                    </a>
                    <a class="@(ctrl == "Department" ? "active" : "")" href="@Url.Action("DepartmentList", "Admin")">
                        <i class="fas fa-hospital"></i><span>Chuyên khoa</span>
                    </a>

                    <div class="nav-section">Bệnh nhân & lịch</div>
                    <a class="@(ctrl == "Patient" && action != "Create" ? "active" : "")" href="@Url.Action("Index", "Patient")">
                        <i class="fas fa-user-injured"></i><span>Bệnh nhân</span>
                    </a>
                    <a class="@(ctrl == "Appointment" && action != "Create" ? "active" : "")" href="@Url.Action("Index", "Appointment")">
                        <i class="fas fa-calendar-check"></i><span>Lịch khám</span>
                    </a>
                    <a class="@(ctrl == "Appointment" && action == "Create" ? "active" : "")" href="@Url.Action("Create", "Appointment")">
                        <i class="fas fa-calendar-plus"></i><span>Tạo lịch khám</span>
                    </a>
                    <a class="@(ctrl == "MedicalRecord" ? "active" : "")" href="@Url.Action("Index", "MedicalRecord")">
                        <i class="fas fa-folder-open"></i><span>Hồ sơ khám</span>
                    </a>
                }
                else if (role == "Receptionist")
                {
                    <div class="nav-section">Tiếp nhận</div>
                    <a class="@(ctrl == "Appointment" && action != "Create" ? "active" : "")" href="@Url.Action("Index", "Appointment")">
                        <i class="fas fa-calendar-check"></i><span>Lịch khám</span>
                    </a>
                    <a class="@(ctrl == "Appointment" && action == "Create" ? "active" : "")" href="@Url.Action("Create", "Appointment")">
                        <i class="fas fa-calendar-plus"></i><span>Tạo lịch khám</span>
                    </a>
                    <a class="@(ctrl == "Patient" && action != "Create" ? "active" : "")" href="@Url.Action("Index", "Patient")">
                        <i class="fas fa-user-injured"></i><span>Bệnh nhân</span>
                    </a>
                    <a class="@(ctrl == "Patient" && action == "Create" ? "active" : "")" href="@Url.Action("Create", "Patient")">
                        <i class="fas fa-user-plus"></i><span>Tiếp nhận mới</span>
                    </a>
                }
                else if (role == "Doctor")
                {
                    <div class="nav-section">Bác sĩ</div>
                    <a class="@(ctrl == "DoctorPortal" ? "active" : "")" href="@Url.Action("MySchedule", "DoctorPortal")">
                        <i class="fas fa-stethoscope"></i><span>Lịch của tôi</span>
                    </a>
                }

                <div class="nav-section">Công khai</div>
                <a href="@Url.Action("Index", "Home")" target="_blank">
                    <i class="fas fa-globe"></i><span>Xem website</span>
                </a>
            </div>

            <div class="sb-footer">
                <div class="sb-user">
                    <div class="av-c av-blue">@initial</div>
                    <div>
                        <div class="sb-user-name">@userName</div>
                        <div class="sb-user-role">@role</div>
                    </div>
                </div>

                <div class="mt-3">
                    <a href="@Url.Action("Logout", "Account")"
                       onclick="return confirm('Bạn có chắc muốn đăng xuất?');"
                       class="btn btn-sm btn-outline-secondary w-100">
                        <i class="fas fa-right-from-bracket me-1"></i>Đăng xuất
                    </a>
                </div>
            </div>
        </aside>

        <main class="main">
            <div class="topbar">
                <div class="topbar-left">
                    <div class="topbar-title">@title</div>
                    <div class="topbar-sub" id="topbar-date"></div>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <span style="font-size:.78rem;color:#64748b">
                        Xin chào, <strong>@shortName</strong>
                    </span>
                    <span class="bs bs-active">@role</span>
                </div>
            </div>

            <div class="page-body">
                @RenderBody()
            </div>
        </main>
    </div>

    <a href="#" id="backToTop" class="back-to-top" aria-label="Lên đầu trang">
        <i class="fas fa-chevron-up"></i>
    </a>
    <style>
        .back-to-top {
            position: fixed; right: 24px; bottom: 28px; width: 48px; height: 48px;
            border-radius: 50%; background: linear-gradient(135deg, #1d4ed8, #0ea5e9);
            color: #fff !important; display: inline-flex; align-items: center; justify-content: center;
            font-size: 18px; text-decoration: none !important;
            box-shadow: 0 12px 28px rgba(29,78,216,.4);
            opacity: 0; transform: translateY(20px) scale(.8); pointer-events: none;
            transition: all .3s ease; z-index: 9999; cursor: pointer;
            border: 2px solid rgba(255,255,255,0.2);
        }
        .back-to-top.show { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
        .back-to-top:hover { transform: translateY(-3px) scale(1.05); box-shadow: 0 16px 36px rgba(29,78,216,.55); }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            var days = ['Chủ nhật', 'Thứ hai', 'Thứ ba', 'Thứ tư', 'Thứ năm', 'Thứ sáu', 'Thứ bảy'];
            var d = new Date();
            var el = document.getElementById('topbar-date');
            if (el) {
                el.textContent =
                    days[d.getDay()] + ', ' +
                    String(d.getDate()).padStart(2, '0') + '/' +
                    String(d.getMonth() + 1).padStart(2, '0') + '/' +
                    d.getFullYear();
            }
        })();

        // ========== Form UX: overlay loading + chặn double-submit triệt để ==========
        (function () {
            document.addEventListener('invalid', function (e) {
                var el = e.target;
                setTimeout(function () {
                    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }, 0);
            }, true);

            function showOverlay() {
                if (document.getElementById('__submitOverlay')) return;
                var ov = document.createElement('div');
                ov.id = '__submitOverlay';
                ov.style.cssText = 'position:fixed;inset:0;background:rgba(15,23,42,.45);z-index:99999;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(3px)';
                ov.innerHTML = '<div style="background:#fff;padding:20px 32px;border-radius:14px;font-weight:700;color:#0f172a;box-shadow:0 20px 40px rgba(0,0,0,.25);font-size:.95rem;display:flex;align-items:center;gap:12px"><div style="width:24px;height:24px;border:3px solid #dbeafe;border-top-color:#2563eb;border-radius:50%;animation:__spn 0.8s linear infinite"></div>Đang xử lý, vui lòng chờ...</div>';
                document.body.appendChild(ov);
                if (!document.getElementById('__spnStyle')) {
                    var st = document.createElement('style');
                    st.id = '__spnStyle';
                    st.textContent = '@@keyframes __spn { to { transform: rotate(360deg) } }';
                    document.head.appendChild(st);
                }
            }

            function removeOverlay() {
                var o = document.getElementById('__submitOverlay');
                if (o) o.remove();
            }

            document.addEventListener('submit', function (e) {
                var form = e.target;
                if (!form || form.tagName !== 'FORM') return;

                // Nếu form có HTML5 validation và fail → browser đã ngăn submit, không show overlay
                if (!form.hasAttribute('novalidate')
                    && typeof form.checkValidity === 'function'
                    && !form.checkValidity()) {
                    return;
                }

                // Form valid → show overlay NGAY + disable button
                showOverlay();

                var btn = form.querySelector('button[type=submit]:not([disabled]), input[type=submit]:not([disabled])');
                if (btn) {
                    btn.disabled = true;
                    btn.style.opacity = '0.7';
                    btn.style.pointerEvents = 'none';
                }

                // Safety: remove overlay + enable sau 15s nếu trang chưa chuyển
                setTimeout(function () {
                    removeOverlay();
                    if (btn) {
                        btn.disabled = false;
                        btn.style.opacity = '';
                        btn.style.pointerEvents = '';
                    }
                }, 15000);
            });

            // Khi user nhấn back/forward → trang load lại → remove overlay (an toàn)
            window.addEventListener('pageshow', removeOverlay);
        })();

        // Back-to-top button: hiện khi scroll > 300px, click cuộn về đầu
        (function () {
            var btn = document.getElementById('backToTop');
            if (!btn) return;
            // Element có thể nằm trong vùng cuộn của .pg-container thay vì window
            var scrollEl = document.scrollingElement || document.documentElement;
            function getScrollTop() { return Math.max(window.scrollY || 0, scrollEl.scrollTop || 0); }
            function toggle() {
                if (getScrollTop() > 300) btn.classList.add('show');
                else btn.classList.remove('show');
            }
            window.addEventListener('scroll', toggle, { passive: true });
            // Một số layout admin dùng main scroll riêng → bind thêm vào main nếu có
            var mainEl = document.querySelector('main') || document.querySelector('.pg-container');
            if (mainEl) mainEl.addEventListener('scroll', toggle, { passive: true });
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                window.scrollTo({ top: 0, behavior: 'smooth' });
                if (mainEl) mainEl.scrollTo({ top: 0, behavior: 'smooth' });
            });
            toggle();
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>