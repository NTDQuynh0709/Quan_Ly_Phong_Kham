@{
    var nav = (ViewBag.Nav ?? "").ToString();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Phòng khám MedicCare</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="~/Content/clinic.css" rel="stylesheet" />
</head>
<body class="public-body">

    <div class="pub-topbar">
        <div class="container d-flex flex-wrap justify-content-between gap-3">
            <div class="d-flex flex-wrap gap-3">
                <span><i class="fas fa-map-marker-alt me-2"></i>45 Đường Láng, Đống Đa, Hà Nội</span>
                <span><i class="fas fa-phone me-2"></i>Hotline: (024) 3866 8899</span>
                <span><i class="fas fa-envelope me-2"></i>info@medicare-clinic.vn</span>
            </div>
            <div>
                <i class="fas fa-clock me-2"></i>Thứ 2 - Thứ 6: 07:30 - 17:00 | Thứ 7: 07:30 - 12:00
            </div>
        </div>
    </div>

    <nav class="pub-nav navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="@Url.Action("Index", "Home")">
                <i class="fas fa-hospital-alt"></i> MedicCare
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#pubNav">
                <i class="fas fa-bars text-white"></i>
            </button>

            <div class="collapse navbar-collapse" id="pubNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link @(nav == "home" ? "active" : "")" href="@Url.Action("Index", "Home")">
                            Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(nav == "doctors" ? "active" : "")" href="@Url.Action("Doctors", "Home")">
                            Đội ngũ bác sĩ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(nav == "booking" ? "active" : "")" href="@Url.Action("Create", "Booking")">
                            Đặt lịch khám
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(nav == "lookup" ? "active" : "")" href="@Url.Action("Lookup", "Booking")">
                            Tra cứu lịch hẹn
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(nav == "about" ? "active" : "")" href="@Url.Action("About", "Home")">
                            Giới thiệu
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(nav == "contact" ? "active" : "")" href="@Url.Action("Contact", "Home")">
                            Liên hệ
                        </a>
                    </li>
                </ul>

                <div class="d-flex gap-2">
                    <a href="@Url.Action("Create", "Booking")" class="btn btn-book-now">
                        <i class="fas fa-calendar-check me-1"></i>Đặt lịch ngay
                    </a>
                    <a href="@Url.Action("Login", "Account")" class="btn btn-login-public">
                        <i class="fas fa-right-to-bracket me-1"></i>Đăng nhập
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="public-main">
        @RenderBody()
    </main>

    <footer class="pub-footer">
        <div class="footer-main">
            <div class="container">
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="footer-brand">
                            <i class="fas fa-hospital-alt me-2"></i>Phòng khám MedicCare
                        </div>
                        <p class="footer-text">
                            Hệ thống đặt lịch khám trực tuyến, tra cứu lịch hẹn và theo dõi hồ sơ khám minh bạch,
                            chuyên nghiệp, phù hợp mô hình phòng khám đa khoa hiện đại.
                        </p>
                    </div>

                    <div class="col-md-4">
                        <div class="footer-title">Thông tin liên hệ</div>
                        <ul class="footer-list">
                            <li><i class="fas fa-map-marker-alt"></i><span>45 Đường Láng, Đống Đa, Hà Nội</span></li>
                            <li><i class="fas fa-phone"></i><span>(024) 3866 8899</span></li>
                            <li><i class="fas fa-envelope"></i><span>info@medicare-clinic.vn</span></li>
                            <li><i class="fas fa-globe"></i><span>www.medicare-clinic.vn</span></li>
                        </ul>
                    </div>

                    <div class="col-md-4">
                        <div class="footer-title">Giờ làm việc</div>
                        <ul class="footer-list">
                            <li><i class="fas fa-clock"></i><span>Thứ 2 - Thứ 6: 07:30 - 17:00</span></li>
                            <li><i class="fas fa-clock"></i><span>Thứ 7: 07:30 - 12:00</span></li>
                            <li><i class="fas fa-times-circle"></i><span>Chủ nhật: Nghỉ</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            © 2026 Phòng khám MedicCare — 45 Đường Láng, Đống Đa, Hà Nội | (024) 3866 8899
        </div>
    </footer>

    <a href="#" id="backToTop" class="back-to-top" aria-label="Lên đầu trang">
        <i class="fas fa-chevron-up"></i>
    </a>
    <style>
        .back-to-top {
            position: fixed; right: 24px; bottom: 28px; width: 48px; height: 48px;
            border-radius: 50%; background: linear-gradient(135deg, #1d4ed8, #0ea5e9);
            color: #fff !important; display: inline-flex; align-items: center; justify-content: center;
            font-size: 18px; text-decoration: none !important;
            box-shadow: 0 12px 28px rgba(29,78,216,.4);
            opacity: 0; transform: translateY(20px) scale(.8); pointer-events: none;
            transition: all .3s ease; z-index: 9999; cursor: pointer;
            border: 2px solid rgba(255,255,255,0.2);
        }
        .back-to-top.show { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
        .back-to-top:hover { transform: translateY(-3px) scale(1.05); box-shadow: 0 16px 36px rgba(29,78,216,.55); }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            var topbar = document.querySelector('.pub-topbar');
            if (!topbar) return;
            var threshold = 40;
            window.addEventListener('scroll', function () {
                if (window.scrollY > threshold) {
                    topbar.classList.add('topbar-hidden');
                } else {
                    topbar.classList.remove('topbar-hidden');
                }
            }, { passive: true });
        })();

        // ========== Form UX: overlay loading + chặn double-submit triệt để ==========
        (function () {
            document.addEventListener('invalid', function (e) {
                var el = e.target;
                setTimeout(function () {
                    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }, 0);
            }, true);

            function showOverlay() {
                if (document.getElementById('__submitOverlay')) return;
                var ov = document.createElement('div');
                ov.id = '__submitOverlay';
                ov.style.cssText = 'position:fixed;inset:0;background:rgba(15,23,42,.45);z-index:99999;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(3px)';
                ov.innerHTML = '<div style="background:#fff;padding:20px 32px;border-radius:14px;font-weight:700;color:#0f172a;box-shadow:0 20px 40px rgba(0,0,0,.25);font-size:.95rem;display:flex;align-items:center;gap:12px"><div style="width:24px;height:24px;border:3px solid #dbeafe;border-top-color:#2563eb;border-radius:50%;animation:__spn 0.8s linear infinite"></div>Đang xử lý, vui lòng chờ...</div>';
                document.body.appendChild(ov);
                if (!document.getElementById('__spnStyle')) {
                    var st = document.createElement('style');
                    st.id = '__spnStyle';
                    st.textContent = '@@keyframes __spn { to { transform: rotate(360deg) } }';
                    document.head.appendChild(st);
                }
            }

            function removeOverlay() {
                var o = document.getElementById('__submitOverlay');
                if (o) o.remove();
            }

            document.addEventListener('submit', function (e) {
                var form = e.target;
                if (!form || form.tagName !== 'FORM') return;

                if (!form.hasAttribute('novalidate')
                    && typeof form.checkValidity === 'function'
                    && !form.checkValidity()) {
                    return;
                }

                showOverlay();

                var btn = form.querySelector('button[type=submit]:not([disabled]), input[type=submit]:not([disabled])');
                if (btn) {
                    btn.disabled = true;
                    btn.style.opacity = '0.7';
                    btn.style.pointerEvents = 'none';
                }

                setTimeout(function () {
                    removeOverlay();
                    if (btn) {
                        btn.disabled = false;
                        btn.style.opacity = '';
                        btn.style.pointerEvents = '';
                    }
                }, 15000);
            });

            window.addEventListener('pageshow', removeOverlay);
        })();

        // Back-to-top button: hiện khi scroll > 300px, click cuộn về đầu
        (function () {
            var btn = document.getElementById('backToTop');
            if (!btn) return;
            function toggle() {
                if (window.scrollY > 300) btn.classList.add('show');
                else btn.classList.remove('show');
            }
            window.addEventListener('scroll', toggle, { passive: true });
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
            toggle();
        })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>