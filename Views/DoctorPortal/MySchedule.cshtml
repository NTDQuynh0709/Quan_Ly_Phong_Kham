@model IEnumerable<web.Models.Appointment>
@{
    ViewBag.Title = "Lịch khám của tôi";
    ViewBag.Ctrl = "DoctorPortal";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var doctor = ViewBag.CurrentDoctor as web.Models.Doctor;

    DateTime now = DateTime.Now;
    string greeting = now.Hour < 12 ? "Chào buổi sáng" : (now.Hour < 18 ? "Chào buổi chiều" : "Chào buổi tối");
    string today = DateTime.Today.ToString("yyyy-MM-dd");
    string tomorrow = DateTime.Today.AddDays(1).ToString("yyyy-MM-dd");
    string selectedDate = ViewBag.SelectedDate ?? today;

    DateTime parsedSelectedDate;
    if (!DateTime.TryParseExact(selectedDate, "yyyy-MM-dd",
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out parsedSelectedDate))
    {
        parsedSelectedDate = DateTime.Today;
        selectedDate = today;
    }
}

<style>
    /* WELCOME HERO */
    .dp-welcome {
        background: linear-gradient(135deg, #1d4ed8, #0ea5e9);
        border-radius: 22px;
        padding: 26px 28px;
        color: #fff;
        margin-bottom: 20px;
        display: flex;
        gap: 22px;
        align-items: center;
        box-shadow: 0 18px 36px rgba(29,78,216,.25);
        position: relative;
        overflow: hidden;
    }

    .dp-welcome::after {
        content: "";
        position: absolute;
        right: -40px;
        top: -40px;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,.1);
    }

    .dp-avatar {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        overflow: hidden;
        background: rgba(255,255,255,.2);
        border: 3px solid rgba(255,255,255,.4);
        flex-shrink: 0;
        box-shadow: 0 6px 14px rgba(0,0,0,.15);
    }

    .dp-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
    }

    .dp-welcome-text {
        flex: 1;
        position: relative;
        z-index: 2;
    }

    .dp-greeting {
        font-size: .88rem;
        opacity: .9;
        margin-bottom: 4px;
    }

    .dp-name {
        font-size: 1.55rem;
        font-weight: 900;
        margin-bottom: 4px;
    }

    .dp-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        color: rgba(255,255,255,.92);
        font-size: .88rem;
    }

        .dp-meta i { opacity: .85; margin-right: 4px; }

    .dp-today {
        background: rgba(255,255,255,.16);
        border: 1px solid rgba(255,255,255,.26);
        border-radius: 14px;
        padding: 12px 18px;
        text-align: center;
        min-width: 140px;
        position: relative;
        z-index: 2;
    }

    .dp-today-lbl { font-size: .76rem; opacity: .86; letter-spacing: .04em; text-transform: uppercase; }
    .dp-today-val { font-size: 1.2rem; font-weight: 800; margin-top: 3px; }

    /* STATS ROW */
    .dp-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        margin-bottom: 20px;
    }

    .dp-stat {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 18px 18px;
        display: flex;
        gap: 14px;
        align-items: center;
        box-shadow: 0 8px 20px rgba(15,23,42,.05);
        transition: .2s ease;
    }

        .dp-stat:hover { transform: translateY(-2px); box-shadow: 0 12px 24px rgba(15,23,42,.09); }

    .dp-stat-ico {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.08rem;
        color: #fff;
        flex-shrink: 0;
    }

    .dp-stat.s1 .dp-stat-ico { background: linear-gradient(135deg,#2563eb,#60a5fa); }
    .dp-stat.s2 .dp-stat-ico { background: linear-gradient(135deg,#d97706,#fbbf24); }
    .dp-stat.s3 .dp-stat-ico { background: linear-gradient(135deg,#16a34a,#4ade80); }
    .dp-stat.s4 .dp-stat-ico { background: linear-gradient(135deg,#4f46e5,#6366f1); }

    .dp-stat-val {
        font-size: 1.5rem;
        font-weight: 900;
        color: #0f172a;
        line-height: 1;
    }

    .dp-stat-lbl {
        color: #64748b;
        font-size: .84rem;
        font-weight: 600;
        margin-top: 4px;
    }

    /* DAY STRIP - 7 ngày tới */
    .dp-daystrip {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 16px 18px;
        margin-bottom: 20px;
        box-shadow: 0 8px 20px rgba(15,23,42,.05);
    }

    .dp-daystrip-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .dp-daystrip-title {
        font-weight: 800;
        color: #0f172a;
        font-size: .98rem;
    }

    .dp-daystrip-sub {
        color: #64748b;
        font-size: .82rem;
    }

    .dp-days {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 10px;
    }

    .dp-day {
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        padding: 12px 8px;
        text-align: center;
        cursor: pointer;
        transition: .18s ease;
        text-decoration: none;
        color: inherit;
        position: relative;
    }

        .dp-day:hover {
            transform: translateY(-2px);
            border-color: #93c5fd;
            background: #eff6ff;
        }

        /* Ngày HÔM NAY thực sự (dt == DateTime.Today) — có ribbon "HÔM NAY" đỏ */
        .dp-day.today {
            background: #fffbeb;
            border: 2px solid #f59e0b;
            position: relative;
        }

            .dp-day.today::before {
                content: "HÔM NAY";
                position: absolute;
                top: -10px;
                left: 50%;
                transform: translateX(-50%);
                background: #dc2626;
                color: #fff;
                font-size: .62rem;
                font-weight: 900;
                padding: 3px 10px;
                border-radius: 999px;
                letter-spacing: .06em;
                box-shadow: 0 4px 10px rgba(220,38,38,.35);
                white-space: nowrap;
            }

            .dp-day.today .dp-day-dd {
                color: #0f172a;
                font-weight: 900;
            }

        /* Ngày đang được CHỌN xem (viền xanh đậm, shadow) */
        .dp-day.active {
            border: 2px solid #1d4ed8;
            box-shadow: 0 8px 22px rgba(29,78,216,.22);
        }

            .dp-day.active:not(.today) {
                background: #fff;
            }

            .dp-day.active .dp-day-dow {
                color: #1d4ed8;
                font-weight: 900;
            }

            .dp-day.active .dp-day-dd {
                color: #0f172a;
                font-weight: 900;
            }

            .dp-day.active .dp-day-mo {
                color: #334155;
                font-weight: 700;
            }

            .dp-day.active .dp-day-count {
                background: #1d4ed8;
                color: #fff;
                font-weight: 800;
            }

        /* Khi vừa TODAY vừa ACTIVE: viền xanh (active) thắng viền vàng (today) */
        .dp-day.today.active {
            border-color: #1d4ed8;
        }

        .dp-day.has-appt { border-color: #bfdbfe; background: #eff6ff; }
        .dp-day.today:not(.active) { border-color: #fbbf24; background: #fffbeb; }

    .dp-day-dow {
        font-size: .72rem;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 4px;
    }

    .dp-day-dd {
        font-size: 1.35rem;
        font-weight: 900;
        color: #0f172a;
        line-height: 1;
    }

    .dp-day-mo {
        font-size: .72rem;
        color: #64748b;
        margin-top: 2px;
    }

    .dp-day-count {
        display: inline-block;
        margin-top: 8px;
        background: #1d4ed8;
        color: #fff;
        font-size: .72rem;
        font-weight: 800;
        padding: 2px 10px;
        border-radius: 999px;
        min-width: 40px;
    }

    .dp-day-count.empty {
        background: #e2e8f0;
        color: #94a3b8;
    }

    .dp-day-dot {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #f59e0b;
        box-shadow: 0 0 0 3px #fffbeb;
    }

    /* QUICK DATE PILLS */
    .dp-filter-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 18px;
        margin-bottom: 20px;
        box-shadow: 0 8px 20px rgba(15,23,42,.05);
    }

    .dp-pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 12px;
    }

    .dp-pill {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 999px;
        padding: 7px 14px;
        font-size: .86rem;
        font-weight: 700;
        text-decoration: none;
        transition: .15s ease;
    }

        .dp-pill:hover { background: #eff6ff; color: #1d4ed8; }
        .dp-pill.active {
            background: linear-gradient(135deg,#1d4ed8,#0ea5e9);
            color: #fff;
            border-color: transparent;
            box-shadow: 0 4px 10px rgba(29,78,216,.3);
        }

    /* TIMELINE */
    .dp-timeline {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 22px 24px;
        box-shadow: 0 8px 20px rgba(15,23,42,.05);
    }

    .dp-tl-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
    }

    .dp-tl-title {
        font-size: 1.02rem;
        font-weight: 800;
        color: #0f172a;
    }

    .dp-tl-count {
        color: #64748b;
        font-size: .86rem;
    }

    .dp-item {
        display: grid;
        grid-template-columns: 72px 1fr;
        gap: 18px;
        padding: 14px 0;
        border-top: 1px dashed #e2e8f0;
    }

        .dp-item:first-of-type { border-top: none; padding-top: 0; }

    .dp-time {
        text-align: center;
        padding: 10px 6px;
        border-radius: 12px;
        background: linear-gradient(135deg,#eff6ff,#dbeafe);
        color: #1d4ed8;
        font-weight: 900;
        font-size: 1rem;
        line-height: 1.2;
        height: fit-content;
    }

    .dp-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 14px 16px;
        border-left: 4px solid #2563eb;
        display: flex;
        justify-content: space-between;
        gap: 14px;
        flex-wrap: wrap;
        transition: .15s ease;
    }

        .dp-card:hover { background: #fff; box-shadow: 0 6px 14px rgba(15,23,42,.08); }

    .dp-card.done { border-left-color: #4f46e5; background: #eef2ff; }
    .dp-card.cancelled { border-left-color: #dc2626; background: #fef2f2; opacity: .82; }
    .dp-card.pending { border-left-color: #f59e0b; background: #fffbeb; }
    .dp-card.confirmed { border-left-color: #16a34a; }

    .dp-card-info { flex: 1; min-width: 220px; }

    .dp-patient-name {
        font-size: 1rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 3px;
    }

    .dp-patient-sub {
        font-size: .82rem;
        color: #64748b;
        margin-bottom: 6px;
    }

    .dp-note {
        color: #334155;
        font-size: .9rem;
        line-height: 1.55;
        margin-top: 4px;
    }

    .dp-card-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
    }

    .dp-fee {
        font-weight: 800;
        color: #0f172a;
        font-size: .92rem;
    }

    .dp-empty {
        text-align: center;
        padding: 50px 20px;
        color: #94a3b8;
    }

        .dp-empty i {
            font-size: 2.2rem;
            opacity: .5;
            margin-bottom: 10px;
            display: block;
        }

    @@media (max-width: 991px) {
        .dp-stats { grid-template-columns: repeat(2, 1fr); }
        .dp-welcome { flex-direction: column; align-items: flex-start; text-align: left; }
        .dp-today { align-self: stretch; }
    }

    @@media (max-width: 640px) {
        .dp-item { grid-template-columns: 60px 1fr; gap: 12px; }
        .dp-stats { grid-template-columns: 1fr; }
    }
</style>

@if (doctor != null)
{
    string avatarUrl = web.Helpers.DoctorAvatarHelper.GetAvatarUrl(doctor.ImageUrl, doctor.FullName);
    string avatarFallback = web.Helpers.DoctorAvatarHelper.GetAvatarDataUri(doctor.FullName);

    <div class="dp-welcome">
        <div class="dp-avatar">
            <img src="@avatarUrl" alt="@doctor.FullName"
                 onerror="this.onerror=null;this.src='@avatarFallback'" />
        </div>

        <div class="dp-welcome-text">
            <div class="dp-greeting">@greeting, chúc một ngày làm việc hiệu quả 👋</div>
            <div class="dp-name">BS. @doctor.FullName</div>
            <div class="dp-meta">
                <span><i class="fas fa-stethoscope"></i>@doctor.Specialty</span>
                @if (doctor.Department != null)
                {
                    <span><i class="fas fa-hospital"></i>@doctor.Department.DepartmentName</span>
                }
                @if (!string.IsNullOrWhiteSpace(doctor.Degree))
                {
                    <span><i class="fas fa-award"></i>@doctor.Degree</span>
                }
            </div>
        </div>

        <div class="dp-today">
            <div class="dp-today-lbl">Hôm nay</div>
            <div class="dp-today-val">@DateTime.Today.ToString("dd/MM/yyyy")</div>
        </div>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-warning mb-3" style="border-radius:12px">
        <i class="fas fa-triangle-exclamation me-2"></i>@TempData["Error"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success mb-3" style="border-radius:12px">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
    </div>
}

<div class="dp-stats">
    <div class="dp-stat s1">
        <div class="dp-stat-ico"><i class="fas fa-calendar-day"></i></div>
        <div>
            <div class="dp-stat-val">@ViewBag.TotalCount</div>
            <div class="dp-stat-lbl">Tổng lịch</div>
        </div>
    </div>
    <div class="dp-stat s2">
        <div class="dp-stat-ico"><i class="fas fa-hourglass-half"></i></div>
        <div>
            <div class="dp-stat-val">@ViewBag.PendingCount</div>
            <div class="dp-stat-lbl">Chờ xác nhận</div>
        </div>
    </div>
    <div class="dp-stat s3">
        <div class="dp-stat-ico"><i class="fas fa-circle-check"></i></div>
        <div>
            <div class="dp-stat-val">@ViewBag.ConfirmedCount</div>
            <div class="dp-stat-lbl">Đã xác nhận</div>
        </div>
    </div>
    <div class="dp-stat s4">
        <div class="dp-stat-ico"><i class="fas fa-file-medical"></i></div>
        <div>
            <div class="dp-stat-val">@ViewBag.DoneCount</div>
            <div class="dp-stat-lbl">Hoàn thành</div>
        </div>
    </div>
</div>

@{
    var upcoming = ViewBag.UpcomingDates as List<web.Controllers.UpcomingDay>;
    int upcomingTotal = ViewBag.UpcomingTotal != null ? (int)ViewBag.UpcomingTotal : 0;
    string[] dowVi = { "CN", "T2", "T3", "T4", "T5", "T6", "T7" };
}

@if (upcoming != null)
{
    <div class="dp-daystrip">
        <div class="dp-daystrip-head">
            <div>
                <div class="dp-daystrip-title"><i class="fas fa-calendar-week me-2 text-primary"></i>Lịch 7 ngày tới</div>
                <div class="dp-daystrip-sub">Click vào ngày bất kỳ để xem chi tiết · @upcomingTotal lịch trong 30 ngày tới</div>
            </div>
        </div>

        <div class="dp-days">
            @foreach (var d in upcoming)
            {
                DateTime dt = d.Date;
                int total = d.Total;
                int pending = d.Pending;
                string dStr = dt.ToString("yyyy-MM-dd");
                bool isActive = selectedDate == dStr;
                bool isToday = dt == DateTime.Today;
                string cls = "dp-day";
                if (isToday) { cls += " today"; }
                if (isActive) { cls += " active"; }
                if (total > 0) { cls += " has-appt"; }

                <a class="@cls" href="@Url.Action("MySchedule", "DoctorPortal", new { date = dStr })">
                    @if (pending > 0 && !isActive)
                    {
                        <span class="dp-day-dot" title="@pending lịch chờ xác nhận"></span>
                    }
                    <div class="dp-day-dow">@dowVi[(int)dt.DayOfWeek]</div>
                    <div class="dp-day-dd">@dt.Day</div>
                    <div class="dp-day-mo">Tháng @dt.Month</div>
                    <span class="dp-day-count @(total == 0 ? "empty" : "")">@total lịch</span>
                </a>
            }
        </div>
    </div>
}

<div class="dp-filter-card">
    @using (Html.BeginForm("MySchedule", "DoctorPortal", FormMethod.Get))
    {
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Ngày cụ thể</label>
                <input type="date" name="date" value="@ViewBag.SelectedDate" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Trạng thái</label>
                <select name="status" class="form-select">
                    <option value="" @(string.IsNullOrWhiteSpace(ViewBag.SelectedStatus) ? "selected" : "")>Tất cả</option>
                    <option value="Pending" @(ViewBag.SelectedStatus == "Pending" ? "selected" : "")>Chờ xác nhận</option>
                    <option value="Confirmed" @(ViewBag.SelectedStatus == "Confirmed" ? "selected" : "")>Đã xác nhận</option>
                    <option value="Done" @(ViewBag.SelectedStatus == "Done" ? "selected" : "")>Hoàn thành</option>
                    <option value="Cancelled" @(ViewBag.SelectedStatus == "Cancelled" ? "selected" : "")>Đã hủy</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Tìm bệnh nhân</label>
                <input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="Tên, CCCD hoặc SĐT" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100">
                    <i class="fas fa-search me-2"></i>Xem
                </button>
            </div>
        </div>
    }
</div>

<div class="dp-timeline">
    <div class="dp-tl-head">
        <div class="dp-tl-title">
            <i class="fas fa-list-ul me-2 text-primary"></i>Lịch khám ngày @parsedSelectedDate.ToString("dd/MM/yyyy")
        </div>
        <div class="dp-tl-count">@Model.Count() lịch hẹn</div>
    </div>

    @if (!Model.Any())
    {
        <div class="dp-empty">
            <i class="fas fa-calendar-times"></i>
            <p>Không có lịch khám nào trong điều kiện đã chọn.</p>
        </div>
    }
    else
    {
        foreach (var item in Model)
        {
            string cardCls = item.Status == "Done" ? "done"
                           : item.Status == "Cancelled" ? "cancelled"
                           : item.Status == "Pending" ? "pending" : "confirmed";

            string statusCls = StatusHelper.StatusClass(item.Status);
            string statusText = StatusHelper.StatusText(item.Status);

            <div class="dp-item">
                <div class="dp-time">
                    <i class="fas fa-clock d-block mb-1" style="font-size:.72rem;opacity:.6"></i>
                    @item.TimeSlot
                </div>

                <div class="dp-card @cardCls">
                    <div class="dp-card-info">
                        <div class="dp-patient-name">@item.Patient.FullName</div>
                        <div class="dp-patient-sub">
                            <i class="fas fa-phone me-1"></i>@item.Patient.Phone
                            <span class="mx-2">·</span>
                            <i class="fas fa-id-card me-1"></i>@item.Patient.CCCD
                        </div>
                        @if (!string.IsNullOrWhiteSpace(item.Note))
                        {
                            <div class="dp-note">
                                <i class="fas fa-note-sticky text-primary me-1"></i>@item.Note
                            </div>
                        }
                    </div>

                    <div class="dp-card-right">
                        <span class="bs @statusCls">@statusText</span>
                        <div class="dp-fee">@String.Format("{0:N0} đ", item.TotalFee)</div>

                        @if (item.Status == "Confirmed" || item.Status == "Done")
                        {
                            <a href="@Url.Action("Edit", "MedicalRecord", new { id = item.Id })"
                               class="btn btn-sm btn-primary">
                                <i class="fas fa-file-medical me-1"></i>@(item.Status == "Done" ? "Xem bệnh án" : "Lập bệnh án")
                            </a>
                        }
                        else if (item.Status == "Pending")
                        {
                            <span style="font-size:.78rem;color:#92400e;font-weight:700">Chờ lễ tân xác nhận</span>
                        }
                        else
                        {
                            <span style="font-size:.78rem;color:#991b1b;font-weight:700">Lịch đã hủy</span>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>
