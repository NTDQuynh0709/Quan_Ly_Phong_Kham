@model IEnumerable<web.Models.Appointment>
@using web.Models

@{
    ViewBag.Title = "Tra cứu lịch hẹn";
    ViewBag.Nav = "lookup";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var patient = ViewBag.PatientInfo as Patient;

    Func<string, string> getStatusClass = status =>
    {
        switch (status)
        {
            case "Confirmed": return "bs-confirmed";
            case "Done": return "bs-done";
            case "Cancelled": return "bs-cancelled";
            default: return "bs-pending";
        }
    };

    Func<string, string> getStatusText = status =>
    {
        switch (status)
        {
            case "Confirmed": return "Đã xác nhận";
            case "Done": return "Hoàn thành";
            case "Cancelled": return "Đã hủy";
            default: return "Chờ xác nhận";
        }
    };
}

<style>
    .lookup-hero {
        background: linear-gradient(135deg, #1d4ed8, #0ea5e9);
        color: #fff;
        padding: 54px 0 40px;
    }

    .lookup-hero-title {
        font-size: 2.2rem;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .lookup-hero-desc {
        max-width: 760px;
        line-height: 1.9;
        color: rgba(255,255,255,.92);
        margin: 0;
    }

    .lookup-wrap {
        background: #f8fafc;
        padding: 40px 0 68px;
    }

    .lookup-search-card,
    .lookup-patient-card,
    .lookup-result-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        box-shadow: 0 12px 26px rgba(15,23,42,.06);
    }

    .lookup-search-card {
        padding: 22px;
        margin-bottom: 24px;
    }

    .lookup-patient-card {
        padding: 20px;
        margin-bottom: 20px;
    }

    .lookup-patient-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
        margin-top: 14px;
    }

    .lookup-patient-box {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 12px 14px;
    }

    .lookup-patient-label {
        font-size: .76rem;
        color: #64748b;
        font-weight: 800;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .lookup-patient-value {
        color: #0f172a;
        font-weight: 800;
        line-height: 1.7;
    }

    .lookup-result-card {
        overflow: hidden;
    }

    .lookup-result-head {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        padding: 18px 20px;
        border-bottom: 1px solid #eef2f7;
        flex-wrap: wrap;
    }

    .lookup-result-title {
        font-size: 1.08rem;
        font-weight: 900;
        color: #0f172a;
    }

    .lookup-result-sub {
        color: #64748b;
        font-size: .86rem;
    }

    .lookup-empty {
        text-align: center;
        padding: 40px 20px;
        color: #64748b;
    }

        .lookup-empty i {
            font-size: 2rem;
            color: #94a3b8;
            margin-bottom: 10px;
            display: block;
        }

    @@media (max-width: 991px) {
        .lookup-patient-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 767px) {
        .lookup-patient-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<section class="lookup-hero">
    <div class="container">
        <div class="lookup-hero-title">Tra cứu lịch hẹn</div>
        <p class="lookup-hero-desc">
            Nhập CCCD, số điện thoại hoặc mã lịch hẹn (BK-xxxxx) đã được cấp khi đặt lịch để xem lại danh sách
            lịch hẹn, trạng thái khám và chi phí khám đã lưu trong hệ thống.
        </p>
    </div>
</section>

<section class="lookup-wrap">
    <div class="container">
        @if (TempData["BookingSuccess"] != null)
        {
            <div class="alert alert-success mb-4">
                <i class="fas fa-check-circle me-2"></i>@TempData["BookingSuccess"]
            </div>
        }

        @if (ViewBag.LookupMessage != null)
        {
            <div class="alert alert-warning mb-4">
                <i class="fas fa-circle-exclamation me-2"></i>@ViewBag.LookupMessage
            </div>
        }

        <div class="lookup-search-card">
            <div style="font-size:1.08rem;font-weight:900;color:#0f172a;margin-bottom:8px;">
                Tìm lịch khám đã đặt
            </div>
            <div style="color:#64748b;line-height:1.8;margin-bottom:16px;">
                Hệ thống hỗ trợ tra cứu bằng <strong>CCCD</strong>, <strong>số điện thoại</strong> hoặc
                <strong>mã lịch hẹn (BK-xxxxx)</strong> đã được cấp khi đặt lịch.
            </div>

            @using (Html.BeginForm("LookupPost", "Booking", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="row g-3 align-items-end">
                    <div class="col-md-9">
                        <label class="form-label">CCCD, số điện thoại hoặc mã lịch hẹn</label>
                        <input type="text" name="keyword"
                               class="form-control"
                               value="@ViewBag.Keyword"
                               placeholder="Ví dụ: BK-00001, 0901234567 (10 số) hoặc 100000000001 (12 số)"
                               required
                               maxlength="15"
                               pattern="([0-9]{10}|[0-9]{12}|[Bb][Kk][-]?[0-9]+)"
                               title="Nhập CCCD (12 chữ số), số điện thoại (10 chữ số) hoặc mã lịch hẹn dạng BK-xxxxx." />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-search me-2"></i>Tra cứu lịch
                        </button>
                    </div>
                </div>
            }
        </div>

        @if (patient != null)
        {
            <div class="lookup-patient-card">
                <div style="font-size:1.14rem;font-weight:900;color:#0f172a;">@patient.FullName</div>
                <div style="color:#64748b;margin-top:4px;">Thông tin bệnh nhân dùng để tra cứu lịch hẹn</div>

                @{
                    string maskedCCCD = !string.IsNullOrWhiteSpace(patient.CCCD) && patient.CCCD.Length >= 4
                        ? new string('*', patient.CCCD.Length - 4) + patient.CCCD.Substring(patient.CCCD.Length - 4)
                        : "****";
                    string maskedPhone = !string.IsNullOrWhiteSpace(patient.Phone) && patient.Phone.Length >= 3
                        ? patient.Phone.Substring(0, 3) + new string('*', patient.Phone.Length - 6) + patient.Phone.Substring(patient.Phone.Length - 3)
                        : "****";
                    string maskedDob = patient.DateOfBirth.HasValue
                        ? "**/**/"+patient.DateOfBirth.Value.Year.ToString()
                        : "—";
                }

                <div class="lookup-patient-grid">
                    <div class="lookup-patient-box">
                        <div class="lookup-patient-label">CCCD</div>
                        <div class="lookup-patient-value">@maskedCCCD</div>
                    </div>
                    <div class="lookup-patient-box">
                        <div class="lookup-patient-label">Số điện thoại</div>
                        <div class="lookup-patient-value">@maskedPhone</div>
                    </div>
                    <div class="lookup-patient-box">
                        <div class="lookup-patient-label">Giới tính</div>
                        <div class="lookup-patient-value">@(string.IsNullOrWhiteSpace(patient.Gender) ? "—" : patient.Gender)</div>
                    </div>
                    <div class="lookup-patient-box">
                        <div class="lookup-patient-label">Ngày sinh</div>
                        <div class="lookup-patient-value">@maskedDob</div>
                    </div>
                </div>

                <div class="alert alert-info mt-3 mb-0" style="font-size:.86rem">
                    <i class="fas fa-shield-halved me-1"></i>Thông tin cá nhân đã được che bớt để bảo mật. Vui lòng liên hệ phòng khám nếu cần xem đầy đủ.
                </div>
            </div>
        }

        @{
            bool canViewResult = ViewBag.AllowViewResult != null && (bool)ViewBag.AllowViewResult;
        }
        @if (!canViewResult && Model.Any() && Model.Any(m => m.Status == "Done"))
        {
            <div class="alert alert-info mb-4" style="border-radius:14px;border:1px solid #bae6fd;background:#f0f9ff">
                <div style="font-weight:800;color:#0c4a6e;margin-bottom:4px">
                    <i class="fas fa-shield-halved me-2"></i>Bảo mật kết quả khám
                </div>
                <div style="color:#075985;line-height:1.7;font-size:.9rem">
                    Vì lý do bảo mật, <strong>kết quả khám chi tiết</strong> (chẩn đoán, đơn thuốc, chỉ số sinh tồn)
                    chỉ hiển thị khi bạn nhập đúng <strong>mã lịch hẹn dạng BK-xxxxx</strong> của lần khám đó.
                    Mã lịch được cấp cho bạn sau khi đặt lịch thành công.
                </div>
            </div>
        }

        <div class="lookup-result-card">
            <div class="lookup-result-head">
                <div>
                    <div class="lookup-result-title">Danh sách lịch hẹn</div>
                    <div class="lookup-result-sub">@Model.Count() lịch hẹn được tìm thấy</div>
                </div>

                <a href="@Url.Action("Create", "Booking")" class="btn btn-outline-primary">
                    <i class="fas fa-calendar-plus me-2"></i>Đặt lịch mới
                </a>
            </div>

            @if (!Model.Any())
            {
                <div class="lookup-empty">
                    <i class="fas fa-calendar-xmark"></i>
                    <div style="font-weight:800;color:#0f172a;margin-bottom:6px;">Chưa có lịch hẹn nào</div>
                    <div>Nhập CCCD, số điện thoại hoặc mã lịch BK-xxxxx để tra cứu, hoặc tạo một lịch khám mới.</div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="tbl">
                        <thead>
                            <tr>
                                <th>Mã lịch</th>
                                <th>Ngày khám</th>
                                <th>Giờ</th>
                                <th>Bác sĩ</th>
                                <th>Khoa</th>
                                <th>Phí khám</th>
                                <th>Trạng thái</th>
                                <th>Kết quả khám</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                bool allowViewResult = ViewBag.AllowViewResult != null && (bool)ViewBag.AllowViewResult;
                            }
                            @foreach (var item in Model)
                            {
                                var record = item.MedicalRecords != null ? item.MedicalRecords.FirstOrDefault() : null;
                                <tr>
                                    <td><code style="background:#eff6ff;color:#1d4ed8;padding:2px 8px;border-radius:6px;font-weight:700">BK-@item.Id.ToString("D5")</code></td>
                                    <td>@item.AppointmentDate.ToString("dd/MM/yyyy")</td>
                                    <td>@item.TimeSlot</td>
                                    <td>@item.Doctor.FullName</td>
                                    <td>@(item.Doctor.Department != null ? item.Doctor.Department.DepartmentName : "—")</td>
                                    <td>@String.Format("{0:N0} đ", item.TotalFee)</td>
                                    <td>
                                        <span class="bs @getStatusClass(item.Status)">
                                            @getStatusText(item.Status)
                                        </span>
                                    </td>
                                    <td>
                                        @if (record != null && allowViewResult)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary"
                                                    data-bs-toggle="modal" data-bs-target="#mrModal-@item.Id">
                                                <i class="fas fa-file-medical me-1"></i>Xem kết quả
                                            </button>
                                        }
                                        else if (record != null && !allowViewResult)
                                        {
                                            <span style="color:#64748b;font-size:.82rem;font-style:italic">
                                                <i class="fas fa-lock me-1"></i>Nhập mã BK-@item.Id.ToString("D5") để xem
                                            </span>
                                        }
                                        else if (item.Status == "Done")
                                        {
                                            <span style="color:#94a3b8;font-style:italic">Đang chờ bác sĩ lập bệnh án</span>
                                        }
                                        else
                                        {
                                            <span style="color:#94a3b8">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* ============ Modal kết quả khám — chỉ render khi được phép xem ============ *@
                foreach (var item in Model)
                {
                    if (!allowViewResult) { continue; }
                    var rec = item.MedicalRecords != null ? item.MedicalRecords.FirstOrDefault() : null;
                    if (rec == null) { continue; }
                    <div class="modal fade" id="mrModal-@item.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-lg modal-dialog-scrollable">
                            <div class="modal-content" style="border-radius:18px;border:none">
                                <div class="modal-header" style="background:linear-gradient(135deg,#1d4ed8,#0ea5e9);color:#fff;border-radius:18px 18px 0 0">
                                    <h5 class="modal-title" style="font-weight:800">
                                        <i class="fas fa-file-medical me-2"></i>Kết quả khám - BK-@item.Id.ToString("D5")
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body" style="padding:22px">
                                    <div style="color:#64748b;margin-bottom:16px">
                                        <strong style="color:#0f172a">@item.Doctor.FullName</strong>
                                        @if (item.Doctor.Department != null)
                                        {
                                            <span> - @item.Doctor.Department.DepartmentName</span>
                                        }
                                        <span> | @item.AppointmentDate.ToString("dd/MM/yyyy") - @item.TimeSlot</span>
                                    </div>

                                    @{
                                        bool hasVitals = !string.IsNullOrWhiteSpace(rec.BloodPressure)
                                                         || rec.HeartRate.HasValue
                                                         || rec.Temperature.HasValue
                                                         || rec.Height.HasValue
                                                         || rec.Weight.HasValue;
                                    }
                                    @if (hasVitals)
                                    {
                                        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px">
                                            @if (!string.IsNullOrWhiteSpace(rec.BloodPressure))
                                            {
                                                <span style="background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;border-radius:999px;padding:6px 14px;font-size:.85rem;font-weight:700">
                                                    <i class="fas fa-heart-pulse me-1"></i>HA: @rec.BloodPressure mmHg
                                                </span>
                                            }
                                            @if (rec.HeartRate.HasValue)
                                            {
                                                <span style="background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;border-radius:999px;padding:6px 14px;font-size:.85rem;font-weight:700">
                                                    <i class="fas fa-wave-square me-1"></i>Mạch: @rec.HeartRate lần/phút
                                                </span>
                                            }
                                            @if (rec.Temperature.HasValue)
                                            {
                                                <span style="background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;border-radius:999px;padding:6px 14px;font-size:.85rem;font-weight:700">
                                                    <i class="fas fa-temperature-half me-1"></i>Nhiệt độ: @rec.Temperature.Value.ToString("0.0") °C
                                                </span>
                                            }
                                            @if (rec.Height.HasValue)
                                            {
                                                <span style="background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;border-radius:999px;padding:6px 14px;font-size:.85rem;font-weight:700">
                                                    <i class="fas fa-ruler-vertical me-1"></i>Cao: @rec.Height.Value.ToString("0.#") cm
                                                </span>
                                            }
                                            @if (rec.Weight.HasValue)
                                            {
                                                <span style="background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;border-radius:999px;padding:6px 14px;font-size:.85rem;font-weight:700">
                                                    <i class="fas fa-weight-scale me-1"></i>Nặng: @rec.Weight.Value.ToString("0.#") kg
                                                </span>
                                            }
                                        </div>
                                    }

                                    <div style="display:grid;gap:12px">
                                        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:14px;padding:14px 16px">
                                            <div style="font-size:.78rem;font-weight:800;color:#64748b;margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em">
                                                <i class="fas fa-clipboard-list me-1"></i>Triệu chứng
                                            </div>
                                            <div style="color:#0f172a;white-space:pre-line;line-height:1.7">@(string.IsNullOrWhiteSpace(rec.Symptoms) ? "—" : rec.Symptoms)</div>
                                        </div>

                                        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:14px;padding:14px 16px">
                                            <div style="font-size:.78rem;font-weight:800;color:#64748b;margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em">
                                                <i class="fas fa-stethoscope me-1"></i>Chẩn đoán
                                            </div>
                                            <div style="color:#0f172a;white-space:pre-line;line-height:1.7">@(string.IsNullOrWhiteSpace(rec.Diagnosis) ? "—" : rec.Diagnosis)</div>
                                        </div>

                                        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:14px;padding:14px 16px">
                                            <div style="font-size:.78rem;font-weight:800;color:#64748b;margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em">
                                                <i class="fas fa-notes-medical me-1"></i>Hướng điều trị
                                            </div>
                                            <div style="color:#0f172a;white-space:pre-line;line-height:1.7">@(string.IsNullOrWhiteSpace(rec.Treatment) ? "—" : rec.Treatment)</div>
                                        </div>

                                        <div style="background:#fef3c7;border:1px solid #fde68a;border-radius:14px;padding:14px 16px">
                                            <div style="font-size:.78rem;font-weight:800;color:#92400e;margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em">
                                                <i class="fas fa-pills me-1"></i>Đơn thuốc
                                            </div>
                                            <div style="color:#0f172a;white-space:pre-line;line-height:1.7;font-family:Consolas,monospace;font-size:.92rem">@(string.IsNullOrWhiteSpace(rec.Prescription) ? "—" : rec.Prescription)</div>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(rec.Note))
                                        {
                                            <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:14px;padding:14px 16px">
                                                <div style="font-size:.78rem;font-weight:800;color:#64748b;margin-bottom:6px;text-transform:uppercase;letter-spacing:.04em">
                                                    <i class="fas fa-comment-medical me-1"></i>Dặn dò của bác sĩ
                                                </div>
                                                <div style="color:#0f172a;white-space:pre-line;line-height:1.7">@rec.Note</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>