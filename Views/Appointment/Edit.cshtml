@model web.Models.Appointment

@{
    ViewBag.Title = "Sửa lịch khám";
    ViewBag.Ctrl = "Appointment";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    string apptDate = Model != null ? Model.AppointmentDate.ToString("yyyy-MM-dd") : "";
}

<div class="pg-hd">
    <h4><i class="fas fa-calendar-pen me-2"></i>Sửa lịch khám</h4>
</div>

<div class="card">
    <div class="card-header"><i class="fas fa-notes-medical me-2 text-primary"></i>Thông tin lịch khám</div>
    <div class="card-body">
        @{
            var allErrors = ViewData.ModelState
                .Where(kv => kv.Value.Errors.Count > 0)
                .SelectMany(kv => kv.Value.Errors.Select(e => e.ErrorMessage))
                .Where(m => !string.IsNullOrWhiteSpace(m))
                .Distinct()
                .ToList();
        }
        @if (allErrors.Count > 0)
        {
            <div class="alert alert-danger mb-3" style="border-radius:12px">
                <div style="font-weight:800;margin-bottom:6px">
                    <i class="fas fa-circle-exclamation me-2"></i>Vui lòng kiểm tra lại các thông tin sau:
                </div>
                <ul style="margin:0;padding-left:22px">
                    @foreach (var msg in allErrors)
                    {
                        <li>@msg</li>
                    }
                </ul>
            </div>
        }

        @using (Html.BeginForm("Edit", "Appointment", FormMethod.Post, new { novalidate = "novalidate" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="row">
                <div class="col-12">
                    <div class="mb-3">
                        <label class="form-label">Bệnh nhân</label>
                        <input type="text" class="form-control" value="@ViewBag.PatientDisplay" readonly />
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Bác sĩ</label>
                        @Html.DropDownList("doctorId", ViewBag.Doctors as SelectList, "Chọn bác sĩ", new { @class = "form-select" })
                        @Html.ValidationMessage("doctorId", "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Ngày khám</label>
                        <input type="date"
                               name="appointmentDate"
                               value="@apptDate"
                               class="form-control"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        @Html.ValidationMessage("appointmentDate", "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="mb-3">
                        <label class="form-label">Giờ khám</label>
                        @Html.DropDownList("timeSlot", ViewBag.TimeSlots as SelectList, "Chọn giờ khám", new { @class = "form-select" })
                        @Html.ValidationMessage("timeSlot", "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label">Trạng thái</label>
                        <select name="status" class="form-select">
                            <option value="Pending" @(ViewBag.SelectedStatus == "Pending" ? "selected" : "")>Chờ xác nhận</option>
                            <option value="Confirmed" @(ViewBag.SelectedStatus == "Confirmed" ? "selected" : "")>Đã xác nhận</option>
                            <option value="Cancelled" @(ViewBag.SelectedStatus == "Cancelled" ? "selected" : "")>Đã hủy</option>
                        </select>
                        @Html.ValidationMessage("status", "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="col-12">
                    <div class="mb-3">
                        <label class="form-label">Ghi chú</label>
                        <textarea name="note" class="form-control" rows="4" placeholder="Nhập ghi chú khám bệnh...">@Model.Note</textarea>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-3 mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Lưu thay đổi
                </button>

                <a href="@Url.Action("Index", "Appointment")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        }
    </div>
</div>