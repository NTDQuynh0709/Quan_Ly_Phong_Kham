@model web.Models.Doctor

@{
    ViewBag.Title = "Cập nhật bác sĩ";
    ViewBag.Ctrl = "Doctor";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .doctor-edit-top {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 20px;
        align-items: start;
        margin-bottom: 16px;
    }

    .doctor-preview {
        width: 160px;
        height: 160px;
        border-radius: 18px;
        overflow: hidden;
        background: #eff6ff;
        border: 2px solid #dbeafe;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #2563eb;
        font-size: 2rem;
        font-weight: 800;
    }

        .doctor-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
</style>

<div class="pg-hd">
    <h4><i class="fas fa-user-pen me-2"></i>Cập nhật bác sĩ</h4>
</div>

<div class="card">
    <div class="card-header">
        <i class="fas fa-id-card me-2 text-primary"></i>Thông tin bác sĩ
    </div>

    <div class="card-body">
        @{
            var allErrors = ViewData.ModelState
                .Where(kv => kv.Value.Errors.Count > 0)
                .SelectMany(kv => kv.Value.Errors.Select(e => e.ErrorMessage))
                .Where(m => !string.IsNullOrWhiteSpace(m))
                .Distinct()
                .ToList();
        }
        @if (allErrors.Count > 0)
        {
            <div class="alert alert-danger mb-3" style="border-radius:12px">
                <div style="font-weight:800;margin-bottom:6px">
                    <i class="fas fa-circle-exclamation me-2"></i>Vui lòng kiểm tra lại các thông tin sau:
                </div>
                <ul style="margin:0;padding-left:22px">
                    @foreach (var msg in allErrors)
                    {
                        <li>@msg</li>
                    }
                </ul>
            </div>
        }

        @using (Html.BeginForm("Edit", "Doctor", FormMethod.Post, new { enctype = "multipart/form-data", novalidate = "novalidate" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)
            @Html.HiddenFor(m => m.UserId)
            @Html.HiddenFor(m => m.CreatedAt)
            @Html.HiddenFor(m => m.ImageUrl)

            <div class="doctor-edit-top">
                <div class="doctor-preview">
                    <img src="@web.Helpers.DoctorAvatarHelper.GetAvatarUrl(Model.ImageUrl, Model.FullName)"
                         alt="@Model.FullName"
                         onerror="this.onerror=null;this.src='@web.Helpers.DoctorAvatarHelper.GetAvatarDataUri(Model.FullName)'" />
                </div>

                <div>
                    <div class="fs-title" style="margin-top:0;">Ảnh đại diện & trạng thái</div>

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">Chọn ảnh mới</label>
                            <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                            @Html.ValidationMessage("imageFile", "", new { @class = "text-danger" })
                            <div style="font-size:.78rem;color:#64748b;margin-top:6px;">
                                Nếu không chọn ảnh mới, hệ thống sẽ giữ ảnh hiện tại.
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Trạng thái</label>
                            <div class="form-check mt-2">
                                @Html.CheckBoxFor(m => m.IsActive, new { @class = "form-check-input", id = "IsActive" })
                                <label class="form-check-label" for="IsActive">Đang hoạt động</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="fs-title">Thông tin cá nhân</div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Họ tên <span style="color:red">*</span></label>
                    @Html.TextBoxFor(m => m.FullName, new {
                        @class = "form-control",
                        placeholder = "Nhập họ tên bác sĩ",
                        required = "required",
                        maxlength = "100",
                        pattern = "^[^0-9]+$",
                        title = "Họ tên không được chứa chữ số."
                    })
                    @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Giới tính</label>
                    <select name="Gender" class="form-select">
                        <option value="">Chọn giới tính</option>
                        <option value="Nam" @(Model.Gender == "Nam" ? "selected" : "")>Nam</option>
                        <option value="Nữ" @(Model.Gender == "Nữ" ? "selected" : "")>Nữ</option>
                    </select>
                    @Html.ValidationMessageFor(m => m.Gender, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Ngày sinh</label>
                    @Html.TextBoxFor(m => m.DateOfBirth, "{0:yyyy-MM-dd}", new {
                        @class = "form-control",
                        type = "date",
                        max = DateTime.Today.AddDays(-1).ToString("yyyy-MM-dd"),
                        min = "1900-01-01"
                    })
                    @Html.ValidationMessageFor(m => m.DateOfBirth, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Số điện thoại <span style="color:red">*</span></label>
                    @Html.TextBoxFor(m => m.Phone, new {
                        @class = "form-control",
                        type = "tel",
                        placeholder = "0901234567",
                        required = "required",
                        minlength = "10",
                        maxlength = "10",
                        pattern = "0[3-9][0-9]{8}",
                        inputmode = "numeric",
                        title = "SĐT phải gồm 10 chữ số, đầu 03/05/07/08/09."
                    })
                    @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email", placeholder = "doctor@medicare.vn" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Địa chỉ</label>
                    @Html.TextBoxFor(m => m.Address, new { @class = "form-control", placeholder = "Nhập địa chỉ" })
                    @Html.ValidationMessageFor(m => m.Address, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="fs-title">Thông tin chuyên môn</div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Chuyên khoa <span style="color:red">*</span></label>
                    @Html.TextBoxFor(m => m.Specialty, new { @class = "form-control", placeholder = "Nhập chuyên khoa" })
                    @Html.ValidationMessageFor(m => m.Specialty, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Khoa / Phòng ban <span style="color:red">*</span></label>
                    @Html.DropDownListFor(m => m.DepartmentId, ViewBag.DeptId as SelectList, "Chọn phòng ban", new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.DepartmentId, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Học vị / chức danh</label>
                    @Html.TextBoxFor(m => m.Degree, new { @class = "form-control", placeholder = "BS.CKI - Tim mạch" })
                    @Html.ValidationMessageFor(m => m.Degree, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-3">
                    <label class="form-label">Số năm kinh nghiệm</label>
                    @Html.TextBoxFor(m => m.YearsOfExperience, new { @class = "form-control", type = "number", min = "0", max = "60" })
                    @Html.ValidationMessageFor(m => m.YearsOfExperience, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-3">
                    <label class="form-label">Giá khám (VNĐ)</label>
                    @Html.TextBoxFor(m => m.ConsultationFee, new { @class = "form-control", type = "number", min = "0", step = "1000" })
                    @Html.ValidationMessageFor(m => m.ConsultationFee, "", new { @class = "text-danger" })
                </div>

                <div class="col-12">
                    <label class="form-label">Giới thiệu bác sĩ</label>
                    @Html.TextAreaFor(m => m.Biography, new { @class = "form-control", rows = "4", placeholder = "Giới thiệu chuyên môn, kinh nghiệm, lĩnh vực khám..." })
                    @Html.ValidationMessageFor(m => m.Biography, "", new { @class = "text-danger" })
                </div>

                <div class="col-12">
                    <label class="form-label">Lịch làm việc</label>
                    @Html.TextBoxFor(m => m.WorkSchedule, new { @class = "form-control", placeholder = "Thứ 2 - Thứ 6 | 07:30 - 17:00; Thứ 7 | 07:30 - 12:00" })
                    @Html.ValidationMessageFor(m => m.WorkSchedule, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="d-flex flex-wrap gap-3 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Lưu thay đổi
                </button>

                <a href="@Url.Action("Index", "Doctor")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        }
    </div>
</div>