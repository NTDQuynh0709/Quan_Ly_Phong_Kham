@model web.Models.Doctor

@{
    ViewBag.Title = "Thêm bác sĩ";
    ViewBag.Ctrl = "Doctor";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="pg-hd">
    <h4><i class="fas fa-user-plus me-2"></i>Thêm bác sĩ mới</h4>
</div>

<div class="card">
    <div class="card-header">
        <i class="fas fa-id-card me-2 text-primary"></i>Thông tin bác sĩ
    </div>

    <div class="card-body">
        @{
            var allErrors = ViewData.ModelState
                .Where(kv => kv.Value.Errors.Count > 0)
                .SelectMany(kv => kv.Value.Errors.Select(e => e.ErrorMessage))
                .Where(m => !string.IsNullOrWhiteSpace(m))
                .Distinct()
                .ToList();
        }
        @if (allErrors.Count > 0)
        {
            <div class="alert alert-danger mb-3" style="border-radius:12px">
                <div style="font-weight:800;margin-bottom:6px">
                    <i class="fas fa-circle-exclamation me-2"></i>Vui lòng kiểm tra lại các thông tin sau:
                </div>
                <ul style="margin:0;padding-left:22px">
                    @foreach (var msg in allErrors)
                    {
                        <li>@msg</li>
                    }
                </ul>
            </div>
        }

        @using (Html.BeginForm("Create", "Doctor", FormMethod.Post, new { enctype = "multipart/form-data", novalidate = "novalidate" }))
        {
            @Html.AntiForgeryToken()

            <div class="fs-title">Tài khoản đăng nhập</div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Tên đăng nhập <span style="color:red">*</span></label>
                    <input type="text" name="username" class="form-control" placeholder="Ví dụ: bs_huong" />
                    @Html.ValidationMessage("username", "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Mật khẩu <span style="color:red">*</span></label>
                    <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu" />
                    @Html.ValidationMessage("password", "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="fs-title">Thông tin cá nhân</div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Họ tên <span style="color:red">*</span></label>
                    @Html.TextBoxFor(m => m.FullName, new {
                        @class = "form-control",
                        placeholder = "Nguyễn Thị Hương",
                        required = "required",
                        maxlength = "100",
                        pattern = "^[^0-9]+$",
                        title = "Họ tên không được chứa chữ số."
                    })
                    @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Giới tính</label>
                    <select name="Gender" class="form-select">
                        <option value="">Chọn giới tính</option>
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                    </select>
                    @Html.ValidationMessageFor(m => m.Gender, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Ngày sinh</label>
                    @Html.TextBoxFor(m => m.DateOfBirth, "{0:yyyy-MM-dd}", new {
                        @class = "form-control",
                        type = "date",
                        max = DateTime.Today.AddDays(-1).ToString("yyyy-MM-dd"),
                        min = "1900-01-01"
                    })
                    @Html.ValidationMessageFor(m => m.DateOfBirth, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Số điện thoại <span style="color:red">*</span></label>
                    @Html.TextBoxFor(m => m.Phone, new {
                        @class = "form-control",
                        type = "tel",
                        placeholder = "0901234567",
                        required = "required",
                        minlength = "10",
                        maxlength = "10",
                        pattern = "0[3-9][0-9]{8}",
                        inputmode = "numeric",
                        title = "SĐT phải gồm 10 chữ số, đầu 03/05/07/08/09."
                    })
                    @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "doctor@medicare.vn", type = "email" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Địa chỉ</label>
                    @Html.TextBoxFor(m => m.Address, new { @class = "form-control", placeholder = "Đống Đa, Hà Nội" })
                    @Html.ValidationMessageFor(m => m.Address, "", new { @class = "text-danger" })
                </div>
            </div>

            <div class="fs-title">Thông tin chuyên môn</div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Chuyên khoa <span style="color:red">*</span></label>
                    @Html.TextBoxFor(m => m.Specialty, new { @class = "form-control", placeholder = "Nội tổng quát, Tim mạch..." })
                    @Html.ValidationMessageFor(m => m.Specialty, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Khoa / Phòng ban <span style="color:red">*</span></label>
                    @Html.DropDownListFor(m => m.DepartmentId, ViewBag.DeptId as SelectList, "Chọn phòng ban", new { @class = "form-select" })
                    @Html.ValidationMessageFor(m => m.DepartmentId, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    <label class="form-label">Học vị / chức danh</label>
                    @Html.TextBoxFor(m => m.Degree, new { @class = "form-control", placeholder = "BS.CKI - Nội tổng quát" })
                    @Html.ValidationMessageFor(m => m.Degree, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-3">
                    <label class="form-label">Số năm kinh nghiệm</label>
                    @Html.TextBoxFor(m => m.YearsOfExperience, new { @class = "form-control", type = "number", min = "0", max = "60", placeholder = "10" })
                    @Html.ValidationMessageFor(m => m.YearsOfExperience, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-3">
                    <label class="form-label">Giá khám (VNĐ)</label>
                    @Html.TextBoxFor(m => m.ConsultationFee, new { @class = "form-control", type = "number", min = "0", step = "1000", placeholder = "300000" })
                    @Html.ValidationMessageFor(m => m.ConsultationFee, "", new { @class = "text-danger" })
                </div>

                <div class="col-12">
                    <label class="form-label">Giới thiệu bác sĩ</label>
                    @Html.TextAreaFor(m => m.Biography, new { @class = "form-control", rows = "4", placeholder = "Mô tả ngắn gọn về chuyên môn, kinh nghiệm, định hướng điều trị..." })
                    @Html.ValidationMessageFor(m => m.Biography, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-8">
                    <label class="form-label">Lịch làm việc</label>
                    @Html.TextBoxFor(m => m.WorkSchedule, new { @class = "form-control", placeholder = "Thứ 2 - Thứ 6 | 07:30 - 17:00; Thứ 7 | 07:30 - 12:00" })
                    @Html.ValidationMessageFor(m => m.WorkSchedule, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-4">
                    <label class="form-label">Ảnh bác sĩ</label>
                    <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                    @Html.ValidationMessage("imageFile", "", new { @class = "text-danger" })
                    <div style="font-size:.78rem;color:#64748b;margin-top:6px;">
                        Chấp nhận JPG, PNG, WEBP. Tối đa 3MB.
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-3 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Lưu bác sĩ
                </button>

                <a href="@Url.Action("Index", "Doctor")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        }
    </div>
</div>