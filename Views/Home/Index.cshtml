                    <i class="fas fa-user-doctor me-2"></i>Xem tất cả bác sĩ
                </a>
            </div>
        }
        else
        {
            <div class="hm-empty">
                <i class="fas fa-user-doctor"></i>
                <p>Chưa có bác sĩ nào được hiển thị.</p>
            </div>
        }
    </div>
</section>

