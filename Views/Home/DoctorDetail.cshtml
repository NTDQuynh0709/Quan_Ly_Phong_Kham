@model web.Models.Doctor
@using web.Models

@{
    ViewBag.Title = "Chi tiết bác sĩ";
    ViewBag.Nav = "doctors";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var relatedDoctors = ViewBag.RelatedDoctors as List<Doctor>;
    var img = web.Helpers.DoctorAvatarHelper.GetAvatarUrl(Model.ImageUrl, Model.FullName);
    var imgFallback = web.Helpers.DoctorAvatarHelper.GetAvatarDataUri(Model.FullName);

    int years = Model.YearsOfExperience ?? 0;
}

<style>
    .dd-hero {
        background: linear-gradient(135deg, #1d4ed8, #0ea5e9);
        color: #fff;
        padding: 38px 0 30px;
    }

    .dd-breadcrumb {
        font-size: .86rem;
        color: rgba(255,255,255,.88);
        margin-bottom: 10px;
    }

        .dd-breadcrumb a { color: #fff; font-weight: 600; }
        .dd-breadcrumb span { opacity: .6; margin: 0 6px; }

    .dd-hero-name {
        font-size: 2rem;
        font-weight: 900;
        line-height: 1.18;
        margin: 0;
    }

    .dd-hero-sub {
        margin-top: 6px;
        color: rgba(255,255,255,.9);
        font-weight: 700;
    }

    .dd-wrap {
        background: #f4f7fb;
        padding: 24px 0 68px;
    }

    .dd-main {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 22px;
        align-items: start;
        margin-top: -24px;
    }

    .dd-side, .dd-content, .dd-related {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        box-shadow: 0 14px 28px rgba(15,23,42,.08);
    }

    .dd-side { overflow: hidden; position: sticky; top: 84px; }

    .dd-photo {
        height: 340px;
        background: linear-gradient(160deg, #dbeafe, #eff6ff);
        overflow: hidden;
    }

    .dd-photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        display: block;
    }

    .dd-side-body { padding: 20px; }

    .dd-side-name {
        font-size: 1.22rem;
        font-weight: 900;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .dd-side-degree {
        color: #2563eb;
        font-weight: 700;
        margin-bottom: 10px;
        font-size: .92rem;
    }

    .dd-side-chip {
        display: inline-block;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: .78rem;
        font-weight: 700;
        border-radius: 999px;
        padding: 5px 11px;
        margin-bottom: 14px;
    }

    .dd-fee-box {
        background: linear-gradient(135deg, #1d4ed8, #0ea5e9);
        color: #fff;
        border-radius: 14px;
        padding: 14px 16px;
        margin-bottom: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .dd-fee-box .lbl {
        font-size: .78rem;
        opacity: .86;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .dd-fee-box .val { font-size: 1.35rem; font-weight: 900; }

    .dd-side-row {
        display: flex;
        gap: 10px;
        padding: 10px 0;
        color: #334155;
        border-bottom: 1px dashed #e2e8f0;
        font-size: .92rem;
    }

    .dd-side-row:last-of-type { border-bottom: none; }
    .dd-side-row i { color: #2563eb; width: 16px; margin-top: 3px; }
    .dd-side-row strong { color: #0f172a; font-weight: 800; }

    .dd-btn-book {
        display: block;
        width: 100%;
        background: #16a34a;
        color: #fff;
        border: none;
        padding: 12px 16px;
        border-radius: 12px;
        font-weight: 800;
        font-size: .98rem;
        margin-top: 14px;
        text-align: center;
    }

    .dd-btn-book:hover { background: #15803d; color: #fff; }

    .dd-content { padding: 26px 30px; }
    .dd-sec + .dd-sec { margin-top: 24px; }

    .dd-sec-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1.08rem;
        font-weight: 900;
        color: #1d4ed8;
        margin-bottom: 12px;
        padding-bottom: 10px;
        border-bottom: 2px solid #eff6ff;
    }

    .dd-sec-title i { color: #2563eb; }

    .dd-sec-text {
        color: #475569;
        line-height: 1.95;
        margin: 0;
    }

    .dd-spec-row { display: flex; gap: 8px; flex-wrap: wrap; }

    .dd-spec-chip {
        background: #eff6ff;
        color: #1d4ed8;
        font-weight: 700;
        border-radius: 999px;
        padding: 7px 14px;
        font-size: .88rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .dd-exp-list { margin: 0; padding: 0; list-style: none; }

    .dd-exp-item {
        display: flex;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .dd-exp-item:last-child { border-bottom: none; }

    .dd-exp-item i {
        color: #2563eb;
        font-size: .8rem;
        margin-top: 7px;
        flex-shrink: 0;
    }

    .dd-exp-item strong {
        display: inline-block;
        color: #0f172a;
        margin-right: 6px;
    }

    .dd-contact-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .dd-contact-box {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 14px 16px;
        display: flex;
        gap: 12px;
    }

    .dd-contact-box i {
        color: #2563eb;
        margin-top: 4px;
        font-size: 1rem;
        width: 16px;
        flex-shrink: 0;
    }

    .dd-contact-label {
        font-size: .74rem;
        color: #64748b;
        font-weight: 800;
        margin-bottom: 3px;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .dd-contact-value { color: #0f172a; font-weight: 700; }

    .dd-related { padding: 22px 26px; margin-top: 22px; }

    .dd-related-title {
        font-size: 1.08rem;
        font-weight: 900;
        color: #0f172a;
        margin-bottom: 14px;
    }

    .dd-related-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(230px, 280px));
        justify-content: flex-start;
        gap: 16px;
    }

    .dd-related-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        overflow: hidden;
        transition: transform .2s ease, box-shadow .2s ease;
    }

    .dd-related-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 14px 26px rgba(15,23,42,.09);
    }

    .dd-related-media {
        height: 260px;
        background: linear-gradient(135deg, #dbeafe, #eff6ff);
        overflow: hidden;
    }

    .dd-related-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        display: block;
    }

    .dd-related-body { padding: 14px 16px 16px; }

    .dd-related-name {
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .dd-related-sub {
        color: #64748b;
        font-size: .85rem;
        margin-bottom: 10px;
        min-height: 40px;
    }

    @@media (max-width: 991px) {
        .dd-main { grid-template-columns: 1fr; margin-top: -16px; }
        .dd-side { position: static; }
        .dd-hero-name { font-size: 1.6rem; }
        .dd-related-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @@media (max-width: 767px) {
        .dd-content { padding: 20px; }
        .dd-contact-grid { grid-template-columns: 1fr; }
        .dd-related-grid { grid-template-columns: 1fr; }
    }
</style>

<section class="dd-hero">
    <div class="container">
        <div class="dd-breadcrumb">
            <a href="@Url.Action("Index", "Home")">Trang chủ</a>
            <span>/</span>
            <a href="@Url.Action("Doctors", "Home")">Đội ngũ bác sĩ</a>
            <span>/</span>
            <strong>@Model.FullName</strong>
        </div>

        <h1 class="dd-hero-name">@(string.IsNullOrWhiteSpace(Model.Degree) ? "" : Model.Degree + " - ") @Model.FullName</h1>
        <div class="dd-hero-sub">
            <i class="fas fa-stethoscope me-2"></i>@Model.Specialty
            @if (Model.Department != null)
            {
                <span class="mx-2" style="opacity:.5">·</span>
                <span>@Model.Department.DepartmentName</span>
            }
        </div>
    </div>
</section>

<section class="dd-wrap">
    <div class="container">
        <div class="dd-main">

            <aside class="dd-side">
                <div class="dd-photo">
                    <img src="@img" alt="@Model.FullName"
                         onerror="this.onerror=null;this.src='@imgFallback'" />
                </div>

                <div class="dd-side-body">
                    <div class="dd-side-name">@Model.FullName</div>
                    <div class="dd-side-degree">@(string.IsNullOrWhiteSpace(Model.Degree) ? "Bác sĩ" : Model.Degree)</div>

                    <span class="dd-side-chip">
                        <i class="fas fa-hospital me-1"></i>@(Model.Department != null ? Model.Department.DepartmentName : Model.Specialty)
                    </span>

                    <div class="dd-fee-box">
                        <div>
                            <div class="lbl">Giá khám</div>
                        </div>
                        <div class="val">@String.Format("{0:N0} đ", Model.ConsultationFee)</div>
                    </div>

                    <div class="dd-side-row">
                        <i class="fas fa-award"></i>
                        <div><strong>Kinh nghiệm:</strong> @years năm</div>
                    </div>

                    <div class="dd-side-row">
                        <i class="fas fa-clock"></i>
                        <div><strong>Lịch làm việc:</strong><br />@(string.IsNullOrWhiteSpace(Model.WorkSchedule) ? "Chưa cập nhật" : Model.WorkSchedule)</div>
                    </div>

                    <div class="dd-side-row">
                        <i class="fas fa-building"></i>
                        <div><strong>Phòng khám:</strong><br />MedicCare - 45 Đường Láng, Đống Đa, Hà Nội</div>
                    </div>

                    <a href="@Url.Action("Create", "Booking", new { doctorId = Model.Id })" class="dd-btn-book">
                        <i class="fas fa-calendar-check me-2"></i>Đặt lịch khám
                    </a>
                </div>
            </aside>

            <div class="dd-content">
                <div class="dd-sec">
                    <div class="dd-sec-title"><i class="fas fa-stethoscope"></i>Chuyên môn</div>

                    <div class="dd-spec-row mb-3">
                        <span class="dd-spec-chip"><i class="fas fa-user-doctor"></i>@Model.Specialty</span>
                        @if (Model.Department != null)
                        {
                            <span class="dd-spec-chip"><i class="fas fa-hospital"></i>@Model.Department.DepartmentName</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Gender))
                        {
                            <span class="dd-spec-chip"><i class="fas fa-venus-mars"></i>@Model.Gender</span>
                        }
                    </div>

                    @if (Model.Department != null && !string.IsNullOrWhiteSpace(Model.Department.Description))
                    {
                        <p class="dd-sec-text">@Model.Department.Description</p>
                    }
                </div>

                <div class="dd-sec">
                    <div class="dd-sec-title"><i class="fas fa-award"></i>Kinh nghiệm &amp; bằng cấp</div>

                    <ul class="dd-exp-list">
                        @if (!string.IsNullOrWhiteSpace(Model.Degree))
                        {
                            <li class="dd-exp-item">
                                <i class="fas fa-circle"></i>
                                <div><strong>Học hàm / học vị:</strong>@Model.Degree</div>
                            </li>
                        }

                        <li class="dd-exp-item">
                            <i class="fas fa-circle"></i>
                            <div><strong>Thời gian công tác:</strong>@years năm kinh nghiệm trong lĩnh vực @Model.Specialty</div>
                        </li>

                        @if (Model.Department != null)
                        {
                            <li class="dd-exp-item">
                                <i class="fas fa-circle"></i>
                                <div><strong>Công tác tại:</strong>Khoa @Model.Department.DepartmentName - Phòng khám đa khoa MedicCare</div>
                            </li>
                        }

                        <li class="dd-exp-item">
                            <i class="fas fa-circle"></i>
                            <div><strong>Chuyên tiếp nhận:</strong>Khám, tư vấn và điều trị các bệnh lý thuộc chuyên khoa @Model.Specialty cho người lớn</div>
                        </li>
                    </ul>
                </div>

                <div class="dd-sec">
                    <div class="dd-sec-title"><i class="fas fa-circle-info"></i>Giới thiệu bác sĩ</div>
                    <p class="dd-sec-text">
                        @(string.IsNullOrWhiteSpace(Model.Biography)
                            ? "Thông tin giới thiệu đang được cập nhật. Quý khách vẫn có thể xem chuyên khoa, giá khám và lịch làm việc của bác sĩ ở thông tin bên trái để lựa chọn đặt lịch phù hợp."
                            : Model.Biography)
                    </p>

                    <p class="dd-sec-text mt-2">
                        Bác sĩ nhận khám theo lịch cố định của phòng khám, quý bệnh nhân vui lòng đặt lịch trước để đảm bảo
                        được phục vụ đúng khung giờ mong muốn.
                    </p>
                </div>

                <div class="dd-sec">
                    <div class="dd-sec-title"><i class="fas fa-address-card"></i>Thông tin liên hệ</div>

                    <div class="dd-contact-grid">
                        <div class="dd-contact-box">
                            <i class="fas fa-phone"></i>
                            <div>
                                <div class="dd-contact-label">Điện thoại</div>
                                <div class="dd-contact-value">@(string.IsNullOrWhiteSpace(Model.Phone) ? "Chưa cập nhật" : Model.Phone)</div>
                            </div>
                        </div>

                        <div class="dd-contact-box">
                            <i class="fas fa-envelope"></i>
                            <div>
                                <div class="dd-contact-label">Email</div>
                                <div class="dd-contact-value">@(string.IsNullOrWhiteSpace(Model.Email) ? "Chưa cập nhật" : Model.Email)</div>
                            </div>
                        </div>

                        <div class="dd-contact-box" style="grid-column:1 / -1">
                            <i class="fas fa-location-dot"></i>
                            <div>
                                <div class="dd-contact-label">Địa chỉ phòng khám</div>
                                <div class="dd-contact-value">45 Đường Láng, Đống Đa, Hà Nội</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        @if (relatedDoctors != null && relatedDoctors.Any())
        {
            <div class="dd-related">
                <div class="dd-related-title">
                    <i class="fas fa-user-doctor me-2 text-primary"></i>Bác sĩ cùng chuyên khoa
                </div>

                <div class="dd-related-grid">
                    @foreach (var d in relatedDoctors)
                    {
                        var relatedImg = web.Helpers.DoctorAvatarHelper.GetAvatarUrl(d.ImageUrl, d.FullName);
                        var relatedFallback = web.Helpers.DoctorAvatarHelper.GetAvatarDataUri(d.FullName);

                        <div class="dd-related-card">
                            <div class="dd-related-media">
                                <img src="@relatedImg" alt="@d.FullName"
                                     onerror="this.onerror=null;this.src='@relatedFallback'" />
                            </div>

                            <div class="dd-related-body">
                                <div class="dd-related-name">@d.FullName</div>
                                <div class="dd-related-sub">
                                    @(string.IsNullOrWhiteSpace(d.Degree) ? d.Specialty : d.Degree)
                                    · @String.Format("{0:N0} đ", d.ConsultationFee)
                                </div>

                                <div class="d-flex gap-2">
                                    <a href="@Url.Action("DoctorDetail", "Home", new { id = d.Id })" class="btn btn-outline-primary flex-fill">
                                        <i class="fas fa-eye me-1"></i>Xem
                                    </a>
                                    <a href="@Url.Action("Create", "Booking", new { doctorId = d.Id })" class="btn btn-primary flex-fill">
                                        <i class="fas fa-calendar-check me-1"></i>Đặt
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>
