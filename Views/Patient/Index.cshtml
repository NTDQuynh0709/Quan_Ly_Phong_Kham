@model IEnumerable<web.Models.Patient>

@{
    ViewBag.Title = "Quản lý bệnh nhân";
    ViewBag.Ctrl = "Patient";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .pt-stat {
        border-radius: 16px;
        padding: 16px 18px;
        color: #fff;
        height: 100%;
    }

        .pt-stat .val {
            font-size: 1.6rem;
            font-weight: 800;
            line-height: 1.1;
        }

        .pt-stat .lbl {
            font-size: .84rem;
            opacity: .9;
            margin-top: 4px;
        }

    .pt-blue {
        background: linear-gradient(135deg, #2563eb, #3b82f6);
    }

    .pt-green {
        background: linear-gradient(135deg, #16a34a, #22c55e);
    }

    .patient-name {
        font-weight: 700;
        color: #0f172a;
    }

    .patient-sub {
        color: #64748b;
        font-size: .84rem;
        margin-top: 2px;
    }

    .patient-chip {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 700;
        background: #eff6ff;
        color: #1d4ed8;
        white-space: nowrap;
    }

    /* Bảng bệnh nhân — không xuống dòng header + căn giữa cột ngắn */
    .patient-tbl thead th {
        white-space: nowrap;
        vertical-align: middle;
    }

    .patient-tbl tbody td {
        vertical-align: middle;
    }

        /* Căn giữa: 2=CCCD, 3=SĐT, 4=Ngày sinh, 5=Giới tính */
        .patient-tbl thead th:nth-child(2),
        .patient-tbl thead th:nth-child(3),
        .patient-tbl thead th:nth-child(4),
        .patient-tbl thead th:nth-child(5),
        .patient-tbl tbody td:nth-child(2),
        .patient-tbl tbody td:nth-child(3),
        .patient-tbl tbody td:nth-child(4),
        .patient-tbl tbody td:nth-child(5) {
            text-align: center;
            white-space: nowrap;
        }
</style>

<div class="pg-hd">
    <h4><i class="fas fa-user-injured me-2"></i>Quản lý bệnh nhân</h4>
    <a href="@Url.Action("Create", "Patient")" class="btn btn-primary">
        <i class="fas fa-user-plus me-2"></i>Tiếp nhận mới
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>@TempData["Success"]</div>
}

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="pt-stat pt-blue">
            <div class="val">@ViewBag.TotalCount</div>
            <div class="lbl">Tổng bệnh nhân</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="pt-stat pt-green">
            <div class="val">@ViewBag.FoundCount</div>
            <div class="lbl">Kết quả tìm thấy</div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="fas fa-search me-2 text-primary"></i>Tìm kiếm bệnh nhân</div>
    <div class="card-body">
        @using (Html.BeginForm("Index", "Patient", FormMethod.Get))
        {
            <div class="row g-3 align-items-end">
                <div class="col-md-10">
                    <label class="form-label">Từ khóa</label>
                    <input type="text"
                           name="q"
                           value="@ViewBag.Query"
                           class="form-control"
                           placeholder="Nhập họ tên, CCCD, số điện thoại hoặc email..." />
                </div>

                <div class="col-md-2">
                    <button class="btn btn-primary w-100">
                        <i class="fas fa-search me-2"></i>Tìm
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list-ul me-2 text-primary"></i>Danh sách bệnh nhân</span>
        <span style="font-size:.82rem;color:#64748b">@ViewBag.FoundCount kết quả</span>
    </div>

    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="fas fa-user-slash"></i>
                <p>Không tìm thấy bệnh nhân phù hợp.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
            <table class="tbl patient-tbl">
                <thead>
                    <tr>
                        <th>Họ tên</th>
                        <th>CCCD</th>
                        <th>Số điện thoại</th>
                        <th>Ngày sinh</th>
                        <th>Giới tính</th>
                        <th>Email</th>
                        <th>Địa chỉ</th>
                        <th style="width:100px;white-space:nowrap;text-align:center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <a href="@Url.Action("Detail", "Patient", new { id = item.Id })" class="patient-name" style="text-decoration:none">@item.FullName</a>
                                <div class="patient-sub">Mã BN: @item.Id</div>
                            </td>
                            <td>@item.CCCD</td>
                            <td>@item.Phone</td>
                            <td>@(item.DateOfBirth.HasValue ? item.DateOfBirth.Value.ToString("dd/MM/yyyy") : "—")</td>
                            <td>
                                <span class="patient-chip">@(string.IsNullOrWhiteSpace(item.Gender) ? "Chưa cập nhật" : item.Gender)</span>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(item.Email) ? "—" : item.Email)</td>
                            <td style="max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="@item.Address">@(string.IsNullOrWhiteSpace(item.Address) ? "—" : item.Address)</td>
                            <td style="white-space:nowrap;text-align:center">
                                <a href="@Url.Action("Detail", "Patient", new { id = item.Id })"
                                   class="btn btn-sm btn-outline-secondary me-1" title="Xem chi tiết">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="@Url.Action("Edit", "Patient", new { id = item.Id })"
                                   class="btn btn-sm btn-outline-primary" title="Sửa hồ sơ">
                                    <i class="fas fa-pen"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        }
    </div>
</div>