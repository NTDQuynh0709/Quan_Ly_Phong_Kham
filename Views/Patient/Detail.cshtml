@model web.Models.Patient

@{
    ViewBag.Title = "Chi tiết bệnh nhân";
    ViewBag.Ctrl = "Patient";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var history = ViewBag.History as List<web.Models.Appointment>;
    var records = ViewBag.Records as List<web.Models.MedicalRecord>;
    var role = (Session["UserRole"] ?? "").ToString();
    bool canSeeRecords = role == "Admin";
}

<style>
    .pt-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        box-shadow: 0 10px 24px rgba(15,23,42,.06);
        padding: 22px;
    }

    .pt-name {
        font-size: 1.3rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 6px;
    }

    .pt-sub {
        color: #64748b;
        font-size: .88rem;
        margin-bottom: 14px;
    }

    .pt-meta { display: grid; gap: 10px; }

    .pt-item {
        display: flex;
        gap: 10px;
        color: #334155;
        line-height: 1.6;
    }

        .pt-item i {
            width: 16px;
            color: #2563eb;
            margin-top: 4px;
        }

        .pt-item strong {
            color: #64748b;
            font-size: .78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .04em;
            display: block;
            margin-bottom: 2px;
        }

    .nav-tabs-pt {
        border-bottom: 2px solid #e2e8f0;
        padding: 0 18px;
        margin-bottom: 0;
    }

        .nav-tabs-pt .nav-link {
            border: none;
            background: transparent;
            color: #64748b;
            font-weight: 700;
            padding: 14px 18px;
            border-bottom: 3px solid transparent;
            margin-bottom: -2px;
        }

            .nav-tabs-pt .nav-link.active {
                color: #1d4ed8;
                border-bottom-color: #1d4ed8;
            }

            .nav-tabs-pt .nav-link .count {
                background: #eff6ff;
                color: #1d4ed8;
                border-radius: 999px;
                font-size: .72rem;
                padding: 2px 8px;
                margin-left: 6px;
            }

            .nav-tabs-pt .nav-link.active .count {
                background: #1d4ed8;
                color: #fff;
            }

    .mr-preview {
        padding: 16px 18px;
        border-bottom: 1px solid #f1f5f9;
    }

        .mr-preview:last-child { border-bottom: none; }

    .mr-top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    .mr-date {
        font-weight: 800;
        color: #0f172a;
    }

    .mr-doctor {
        color: #64748b;
        font-size: .88rem;
    }

    .mr-snippet {
        color: #475569;
        font-size: .9rem;
        line-height: 1.7;
        white-space: pre-line;
        max-height: 4.3em;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .mr-chip-row {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 8px;
    }

    .mr-chip {
        background: #f1f5f9;
        color: #334155;
        font-size: .74rem;
        font-weight: 700;
        border-radius: 999px;
        padding: 4px 10px;
    }
</style>

<div class="pg-hd">
    <h4><i class="fas fa-user me-2"></i>Chi tiết bệnh nhân</h4>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Edit", "Patient", new { id = Model.Id })" class="btn btn-outline-primary">
            <i class="fas fa-pen me-2"></i>Sửa hồ sơ
        </a>
        <a href="@Url.Action("Index", "Patient")" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Quay lại
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-5">
        <div class="pt-card">
            <div class="pt-name">@Model.FullName</div>
            <div class="pt-sub">Mã BN: #@Model.Id · Tạo: @Model.CreatedAt.ToString("dd/MM/yyyy")</div>

            <div class="pt-meta">
                <div class="pt-item"><i class="fas fa-id-card"></i><div><strong>CCCD</strong>@Model.CCCD</div></div>
                <div class="pt-item"><i class="fas fa-phone"></i><div><strong>Điện thoại</strong>@Model.Phone</div></div>
                <div class="pt-item"><i class="fas fa-envelope"></i><div><strong>Email</strong>@(string.IsNullOrWhiteSpace(Model.Email) ? "Chưa cập nhật" : Model.Email)</div></div>
                <div class="pt-item"><i class="fas fa-venus-mars"></i><div><strong>Giới tính</strong>@(string.IsNullOrWhiteSpace(Model.Gender) ? "Chưa cập nhật" : Model.Gender)</div></div>
                <div class="pt-item"><i class="fas fa-cake-candles"></i><div><strong>Ngày sinh</strong>@(Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToString("dd/MM/yyyy") : "Chưa cập nhật")</div></div>
                <div class="pt-item"><i class="fas fa-location-dot"></i><div><strong>Địa chỉ</strong>@(string.IsNullOrWhiteSpace(Model.Address) ? "Chưa cập nhật" : Model.Address)</div></div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <ul class="nav nav-tabs nav-tabs-pt" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-appt" type="button">
                        <i class="fas fa-calendar-check me-1"></i>Lịch khám
                        <span class="count">@(history != null ? history.Count : 0)</span>
                    </button>
                </li>
                @if (canSeeRecords)
                {
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-records" type="button">
                            <i class="fas fa-file-medical me-1"></i>Bệnh án
                            <span class="count">@(records != null ? records.Count : 0)</span>
                        </button>
                    </li>
                }
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="tab-appt" role="tabpanel">
                    @if (history == null || !history.Any())
                    {
                        <div class="empty-state">
                            <i class="fas fa-calendar-times"></i>
                            <p>Chưa có lịch khám nào.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                        <table class="tbl">
                            <thead>
                                <tr>
                                    <th>Ngày - Giờ</th>
                                    <th>Bác sĩ</th>
                                    <th>Phí</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in history)
                                {
                                    <tr>
                                        <td>
                                            <div style="font-weight:700;color:#0f172a">@item.AppointmentDate.ToString("dd/MM/yyyy")</div>
                                            <div style="font-size:.82rem;color:#64748b">@item.TimeSlot</div>
                                        </td>
                                        <td>
                                            <div style="font-weight:700;color:#0f172a">@item.Doctor.FullName</div>
                                            <div style="font-size:.82rem;color:#64748b">@item.Doctor.Specialty</div>
                                        </td>
                                        <td style="font-weight:700">@String.Format("{0:N0} đ", item.TotalFee)</td>
                                        <td><span class="bs @StatusHelper.StatusClass(item.Status)">@StatusHelper.StatusText(item.Status)</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    }
                </div>

                @if (canSeeRecords)
                {
                    <div class="tab-pane fade" id="tab-records" role="tabpanel">
                        @if (records == null || !records.Any())
                        {
                            <div class="empty-state">
                                <i class="fas fa-file-medical"></i>
                                <p>Bệnh nhân chưa có hồ sơ bệnh án nào.</p>
                            </div>
                        }
                        else
                        {
                            foreach (var m in records)
                            {
                                <div class="mr-preview">
                                    <div class="mr-top">
                                        <div>
                                            <div class="mr-date">@m.Appointment.AppointmentDate.ToString("dd/MM/yyyy") - @m.Appointment.TimeSlot</div>
                                            <div class="mr-doctor">BS. @m.Appointment.Doctor.FullName · @m.Appointment.Doctor.Specialty</div>
                                        </div>
                                        <div class="mr-chip-row">
                                            @if (!string.IsNullOrWhiteSpace(m.Diagnosis))
                                            {
                                                <span class="mr-chip"><i class="fas fa-stethoscope me-1"></i>@(m.Diagnosis.Length > 40 ? m.Diagnosis.Substring(0, 40) + "..." : m.Diagnosis)</span>
                                            }
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(m.Symptoms))
                                    {
                                        <div class="mr-snippet"><strong>Triệu chứng:</strong> @m.Symptoms</div>
                                    }
                                </div>
                            }

                            <div class="text-center py-3">
                                <a href="@Url.Action("PatientHistory", "MedicalRecord", new { patientId = Model.Id })"
                                   class="btn btn-outline-primary">
                                    <i class="fas fa-folder-open me-2"></i>Xem đầy đủ hồ sơ bệnh án
                                </a>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
