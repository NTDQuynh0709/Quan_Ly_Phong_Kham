@model web.Models.Patient

@{
    ViewBag.Title = "Cập nhật bệnh nhân";
    ViewBag.Ctrl = "Patient";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    string dobValue = Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToString("yyyy-MM-dd") : "";
}

<div class="pg-hd">
    <h4><i class="fas fa-user-pen me-2"></i>Cập nhật hồ sơ bệnh nhân</h4>
</div>

<div class="card">
    <div class="card-header"><i class="fas fa-id-card me-2 text-primary"></i>Thông tin bệnh nhân</div>
    <div class="card-body">
        @{
            var allErrors = ViewData.ModelState
                .Where(kv => kv.Value.Errors.Count > 0)
                .SelectMany(kv => kv.Value.Errors.Select(e => e.ErrorMessage))
                .Where(m => !string.IsNullOrWhiteSpace(m))
                .Distinct()
                .ToList();
        }
        @if (allErrors.Count > 0)
        {
            <div class="alert alert-danger mb-3" style="border-radius:12px">
                <div style="font-weight:800;margin-bottom:6px">
                    <i class="fas fa-circle-exclamation me-2"></i>Vui lòng kiểm tra lại các thông tin sau:
                </div>
                <ul style="margin:0;padding-left:22px">
                    @foreach (var msg in allErrors)
                    {
                        <li>@msg</li>
                    }
                </ul>
            </div>
        }

        @using (Html.BeginForm("Edit", "Patient", FormMethod.Post, new { novalidate = "novalidate" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)

            <div class="row">
                <div class="col-md-6">
                    <div class="field-group mb-3">
                        <label class="form-label">Họ và tên <span style="color:red">*</span></label>
                        @Html.TextBoxFor(m => m.FullName, new {
                            @class = "form-control",
                            placeholder = "Nhập họ tên bệnh nhân",
                            required = "required",
                            maxlength = "100",
                            pattern = "^[^0-9]+$",
                            title = "Họ tên không được chứa chữ số."
                        })
                        @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="field-group mb-3">
                        <label class="form-label">Ngày sinh</label>
                        <input type="date" name="DateOfBirth" value="@dobValue" class="form-control"
                               max="@DateTime.Today.AddDays(-1).ToString("yyyy-MM-dd")"
                               min="1900-01-01" />
                        @Html.ValidationMessageFor(m => m.DateOfBirth, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="field-group mb-3">
                        <label class="form-label">Giới tính</label>
                        <select name="Gender" class="form-select">
                            <option value="">Chọn giới tính</option>
                            <option value="Nam" @(Model.Gender == "Nam" ? "selected" : "")>Nam</option>
                            <option value="Nữ" @(Model.Gender == "Nữ" ? "selected" : "")>Nữ</option>
                        </select>
                        @Html.ValidationMessageFor(m => m.Gender, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="field-group mb-3">
                        <label class="form-label">CCCD <span style="color:red">*</span></label>
                        @Html.TextBoxFor(m => m.CCCD, new {
                            @class = "form-control",
                            placeholder = "Nhập đúng 12 chữ số CCCD",
                            required = "required",
                            minlength = "12",
                            maxlength = "12",
                            pattern = "[0-9]{12}",
                            inputmode = "numeric",
                            title = "CCCD phải gồm đúng 12 chữ số, không có chữ."
                        })
                        @Html.ValidationMessageFor(m => m.CCCD, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="field-group mb-3">
                        <label class="form-label">Số điện thoại <span style="color:red">*</span></label>
                        @Html.TextBoxFor(m => m.Phone, new {
                            @class = "form-control",
                            type = "tel",
                            placeholder = "VD: 0912345678",
                            required = "required",
                            minlength = "10",
                            maxlength = "10",
                            pattern = "0[3-9][0-9]{8}",
                            inputmode = "numeric",
                            title = "SĐT phải gồm 10 chữ số, đầu 03/05/07/08/09."
                        })
                        @Html.ValidationMessageFor(m => m.Phone, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="field-group mb-3">
                        <label class="form-label">Email</label>
                        @Html.TextBoxFor(m => m.Email, new {
                            @class = "form-control",
                            type = "email",
                            placeholder = "email@example.com"
                        })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="col-12">
                    <div class="field-group mb-3">
                        <label class="form-label">Địa chỉ</label>
                        @Html.TextBoxFor(m => m.Address, new { @class = "form-control", placeholder = "Nhập địa chỉ liên hệ" })
                        @Html.ValidationMessageFor(m => m.Address, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-3 mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Lưu thay đổi
                </button>

                <a href="@Url.Action("Index", "Patient")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
                </a>
            </div>
        }
    </div>
</div>