@model web.Models.Department
@{
    ViewBag.Title = "Thêm chuyên khoa";
    ViewBag.Ctrl = "Department";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="pg-hd">
    <h4><i class="fas fa-plus me-2"></i>Thêm chuyên khoa</h4>
</div>

<div class="card">
    <div class="card-header"><i class="fas fa-hospital me-2 text-primary"></i>Thông tin chuyên khoa</div>
    <div class="card-body">
        @{
            var allErrors = ViewData.ModelState
                .Where(kv => kv.Value.Errors.Count > 0)
                .SelectMany(kv => kv.Value.Errors.Select(e => e.ErrorMessage))
                .Where(m => !string.IsNullOrWhiteSpace(m))
                .Distinct()
                .ToList();
        }
        @if (allErrors.Count > 0)
        {
            <div class="alert alert-danger mb-3" style="border-radius:12px">
                <div style="font-weight:800;margin-bottom:6px">
                    <i class="fas fa-circle-exclamation me-2"></i>Vui lòng kiểm tra lại các thông tin sau:
                </div>
                <ul style="margin:0;padding-left:22px">
                    @foreach (var msg in allErrors)
                    {
                        <li>@msg</li>
                    }
                </ul>
            </div>
        }

        @using (Html.BeginForm("DepartmentCreate", "Admin", FormMethod.Post, new { novalidate = "novalidate" }))
        {
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Tên chuyên khoa <span style="color:red">*</span></label>
                    @Html.TextBoxFor(m => m.DepartmentName, new {
                        @class = "form-control",
                        placeholder = "Ví dụ: Nội tổng quát",
                        required = "required",
                        maxlength = "100"
                    })
                    @Html.ValidationMessageFor(m => m.DepartmentName, "", new { @class = "text-danger" })
                </div>

                <div class="col-12">
                    <label class="form-label">Mô tả</label>
                    @Html.TextAreaFor(m => m.Description, new {
                        @class = "form-control",
                        rows = 3,
                        maxlength = "500",
                        placeholder = "Mô tả ngắn về chuyên khoa"
                    })
                </div>
            </div>

            <div class="d-flex flex-wrap gap-3 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Lưu
                </button>
                <a href="@Url.Action("DepartmentList", "Admin")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        }
    </div>
</div>
