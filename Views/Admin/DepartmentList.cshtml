@model IEnumerable<web.Models.Department>
@{
    ViewBag.Title = "Quản lý chuyên khoa";
    ViewBag.Ctrl = "Department";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var counts = ViewBag.DoctorCountByDept as System.Collections.Generic.Dictionary<int, int>;
}

<div class="pg-hd">
    <h4><i class="fas fa-hospital me-2"></i>Quản lý chuyên khoa</h4>
    <a href="@Url.Action("DepartmentCreate", "Admin")" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Thêm chuyên khoa
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger"><i class="fas fa-triangle-exclamation me-2"></i>@TempData["Error"]</div>
}

<div class="card mb-4">
    <div class="card-header"><i class="fas fa-search me-2 text-primary"></i>Tìm chuyên khoa</div>
    <div class="card-body">
        @using (Html.BeginForm("DepartmentList", "Admin", FormMethod.Get))
        {
            <div class="row g-3 align-items-end">
                <div class="col-md-10">
                    <input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="Tên hoặc mô tả chuyên khoa..." />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100"><i class="fas fa-search me-2"></i>Tìm</button>
                </div>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list-ul me-2 text-primary"></i>Danh sách chuyên khoa</span>
        <span style="font-size:.82rem;color:#64748b">@Model.Count() chuyên khoa</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="fas fa-hospital"></i>
                <p>Chưa có chuyên khoa nào.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
            <table class="tbl">
                <thead>
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Tên chuyên khoa</th>
                        <th>Mô tả</th>
                        <th style="width:130px">Bác sĩ</th>
                        <th style="width:180px">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model)
                    {
                        int cnt = (counts != null && counts.ContainsKey(d.Id)) ? counts[d.Id] : 0;
                        <tr>
                            <td>@d.Id</td>
                            <td style="font-weight:700;color:#0f172a">@d.DepartmentName</td>
                            <td>@(string.IsNullOrWhiteSpace(d.Description) ? "—" : d.Description)</td>
                            <td><span class="bs bs-active">@cnt bác sĩ</span></td>
                            <td>
                                <a href="@Url.Action("DepartmentEdit", "Admin", new { id = d.Id })"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    <i class="fas fa-pen me-1"></i>Sửa
                                </a>

                                @using (Html.BeginForm("DepartmentDelete", "Admin", FormMethod.Post, new { style = "display:inline" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@d.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Xóa chuyên khoa @d.DepartmentName? Chỉ xóa được khi không có bác sĩ thuộc khoa này.');">
                                        <i class="fas fa-trash me-1"></i>Xóa
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        }
    </div>
</div>
